// =============================================================================
// prisma/schema/core/student.prisma — RESQID
// Student entity — emergency profile moved to modules/emergency.prisma
// =============================================================================

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Student {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  firstName  String
  lastName   String
  dateOfBirth DateTime?
  gender     Gender?
  photoUrl   String?

  // Class assignment
  grade      String?    // "10"
  section    String?    // "A"

  // Parent link
  parentId   String?
  parent     ParentUser? @relation(fields: [parentId], references: [id])

  // Card visibility
  cardVisibilityId String?
  cardVisibility   CardVisibility?

  isActive   Boolean   @default(true)
  metadata   Json?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  tokens              Token[]
  scans               Scan[]
  attendanceRecords   AttendanceRecord[]
  attendanceTaps      AttendanceTap[]
  emergencyProfile    EmergencyProfile?
  parentLinks         ParentStudent[]

  @@index([schoolId])
  @@index([grade, section])
  @@index([parentId])
  @@map("students")
}

// ─── Card Visibility (parent controls what shows on scan) ─────────────────────

enum VisibilityLevel {
  PUBLIC    // Full profile visible on scan
  MINIMAL   // Only primary contact visible
  HIDDEN    // No data visible
}

model CardVisibility {
  id         String         @id @default(cuid())
  visibility VisibilityLevel @default(PUBLIC)

  students   Student[]

  @@map("card_visibility")
}