// #file: prisma/schema/user.prisma

// ─────────────────────────────────────────────────────────────
// user.prisma
//
// Identity models for every authenticated actor in RESQID.
// Roles are split into separate tables for cleaner design:
//   • SuperAdmin          – platform owner
//   • SchoolUser          – admin, teacher, guard (belongs to a school)
//   • ParentUser          – parent / guardian (OTP‑based auth)
//
// Sessions are polymorphic (one table for all actor types).
// Devices store Expo push tokens for notification delivery.
// ─────────────────────────────────────────────────────────────

// ─── Enums ──────────────────────────────────────────────────

enum SchoolUserRole {
  ADMIN
  TEACHER
  GUARD
}

// ─── Super Admin ────────────────────────────────────────────

model SuperAdmin {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String

  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions     UserSession[]

  @@map("super_admins")
}

// ─── School User (Admin, Teacher, Guard) ────────────────────

model SchoolUser {
  id           String         @id @default(cuid())
  schoolId     String
  school       School         @relation(fields: [schoolId], references: [id])

  name         String
  email        String         @unique
  phone        String?
  passwordHash String
  role         SchoolUserRole @default(TEACHER)

  isActive     Boolean        @default(true)
  lastLoginAt  DateTime?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?      // soft delete

  sessions     UserSession[]

  @@index([schoolId])
  @@index([email])
  @@map("school_users")
}

// ─── Parent User ────────────────────────────────────────────

model ParentUser {
  id           String    @id @default(cuid())
  name         String?
  phone        String    @unique
  email        String?

  // OTP‑based login
  otp          String?
  otpExpiresAt DateTime?
  otpAttempts  Int       @default(0)

  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  students     ParentStudent[]
  sessions     UserSession[]
  devices      Device[]

  @@index([phone])
  @@map("parent_users")
}

// ─── Parent ↔ Student Link (many‑to‑many) ──────────────────

model ParentStudent {
  id        String      @id @default(cuid())
  parentId  String
  parent    ParentUser  @relation(fields: [parentId], references: [id])
  studentId String
  student   Student     @relation(fields: [studentId], references: [id])
  relation  String      @default("PARENT")   // PARENT | GUARDIAN | SIBLING

  isPrimary Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@unique([parentId, studentId])
  @@index([studentId])
  @@map("parent_students")
}

// ─── Session (polymorphic) ──────────────────────────────────

model UserSession {
  id                String      @id @default(cuid())

  // Actor – one of these three must be set (enforced at app level)
  superAdminId      String?
  superAdmin        SuperAdmin? @relation(fields: [superAdminId], references: [id])
  schoolUserId      String?
  schoolUser        SchoolUser? @relation(fields: [schoolUserId], references: [id])
  parentUserId      String?
  parentUser        ParentUser? @relation(fields: [parentUserId], references: [id])

  refreshTokenHash  String      @unique
  deviceFingerprint String?
  deviceInfo        Json?       // { browser, os, device }
  ipAddress         String?

  expiresAt         DateTime
  revokedAt         DateTime?

  createdAt         DateTime    @default(now())

  @@index([superAdminId])
  @@index([schoolUserId])
  @@index([parentUserId])
  @@map("user_sessions")
}

// ─── Device (for push notifications) ────────────────────────

model Device {
  id            String     @id @default(cuid())
  parentId      String
  parent        ParentUser @relation(fields: [parentId], references: [id])

  expoPushToken String?    @unique
  platform      String     // ios | android
  deviceId      String     // unique device identifier

  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([parentId])
  @@map("devices")
}