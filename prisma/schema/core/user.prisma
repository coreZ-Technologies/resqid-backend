// =============================================================================
// prisma/schema/core/user.prisma — RESQID
// Identity models for all authenticated actors
// =============================================================================

enum SchoolUserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
}

// ─── Super Admin ──────────────────────────────────────────────────────────────

model SuperAdmin {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String

  isPasswordDefault  Boolean  @default(false)
  passwordChangedAt  DateTime?

  isActive     Boolean       @default(true)
  lastLoginAt  DateTime?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sessions     UserSession[]

  @@map("super_admins")
}

// ─── School User ──────────────────────────────────────────────────────────────

model SchoolUser {
  id           String         @id @default(cuid())
  schoolId     String
  school       School         @relation(fields: [schoolId], references: [id])

  name         String
  email        String         @unique
  phone        String?
  passwordHash String
  role         SchoolUserRole @default(TEACHER)

  isPasswordDefault  Boolean  @default(true)   // Must change on first login
  passwordChangedAt  DateTime?

  isActive     Boolean        @default(true)
  lastLoginAt  DateTime?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  sessions     UserSession[]

  @@index([schoolId])
  @@index([email])
  @@map("school_users")
}

// ─── Parent User ──────────────────────────────────────────────────────────────

model ParentUser {
  id           String          @id @default(cuid())
  
  // Basic Information
  firstName    String?         // Split name into first/last for better UX
  lastName     String?
  name         String?         // Keep for backward compatibility (full name)
  phone        String          @unique
  email        String?
  photoUrl     String?         // Profile photo
  
  // Address (for emergency situations)
  address      String?
  city         String?
  state        String?
  pincode      String?
  
  // Occupation (useful for school records)
  occupation   String?
  
  // Communication Preferences
  canCall      Boolean         @default(true)
  canWhatsapp  Boolean         @default(true)
  canEmail     Boolean         @default(true)
  canSMS       Boolean         @default(true)
  
  // OTP Authentication
  otp          String?
  otpExpiresAt DateTime?
  otpAttempts  Int             @default(0)
  otpRequestedAt DateTime?     // Track when last OTP was requested
  isPhoneVerified Boolean      @default(false)
  
  // Status
  isActive     Boolean         @default(true)
  lastLoginAt  DateTime?
  lastSeenAt   DateTime?       // For online status
  
  // Emergency Contact Priority (default for all children)
  isEmergencyContact Boolean   @default(true)
  emergencyPriority Int        @default(1)  // 1 = First to call
  
  // Metadata for extensibility
  metadata     Json?
  
  // Timestamps
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?       // Soft delete

  // Relations
  students     ParentStudent[]
  sessions     UserSession[]
  devices      ParentDevice[]
  notifications Notification[]
  preferences  NotificationPreference?
  emergencyContacts EmergencyContact[]  // Parents can have their own emergency contacts

  @@index([phone])
  @@index([email])
  @@index([firstName, lastName])
  @@map("parent_users")
}

// ─── Parent ↔ Student Link ────────────────────────────────────────────────────

model ParentStudent {
  id           String       @id @default(cuid())
  parentId     String
  parent       ParentUser   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  relation     Relationship @default(GUARDIAN)
  
  isPrimary    Boolean      @default(false)
  isEmergency  Boolean      @default(true)
  priority     Int          @default(1)
  canPickup    Boolean      @default(true)
  
  isActive     Boolean      @default(true)
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([parentId, studentId])
  @@index([studentId])
  @@index([parentId])
  @@map("parent_students")
}

// ─── User Session (polymorphic) ───────────────────────────────────────────────

model UserSession {
  id                String       @id @default(cuid())

  superAdminId      String?
  superAdmin        SuperAdmin?  @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  schoolUserId      String?
  schoolUser        SchoolUser?  @relation(fields: [schoolUserId], references: [id], onDelete: Cascade)
  parentUserId      String?
  parentUser        ParentUser?  @relation(fields: [parentUserId], references: [id], onDelete: Cascade)

  refreshTokenHash  String       @unique
  deviceFingerprint String?
  deviceInfo        Json?
  ipAddress         String?

  expiresAt         DateTime
  revokedAt         DateTime?

  createdAt         DateTime     @default(now())

  @@index([superAdminId])
  @@index([schoolUserId])
  @@index([parentUserId])
  @@index([refreshTokenHash])
  @@map("user_sessions")
}

// ─── Parent Device ────────────────────────────────────────────────────────────

model ParentDevice {
  id                String     @id @default(cuid())
  parentId          String
  parent            ParentUser @relation(fields: [parentId], references: [id], onDelete: Cascade)

  deviceFingerprint String     @unique
  platform          String
  expoPushToken     String?    @unique

  isActive          Boolean    @default(true)
  loggedOutAt       DateTime?
  logoutReason      String?
  lastSeenAt        DateTime?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([parentId])
  @@map("parent_devices")
}

// ─── Attendance Device (RFID Machines) ────────────────────────────────────────

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  BLOCKED
  UNREGISTERED
  CONFIGURING
  ERROR
}

model AttendanceDevice {
  id          String       @id @default(cuid())
  schoolId    String
  school      School       @relation(fields: [schoolId], references: [id])

  name        String
  apiKey      String       @unique
  status      DeviceStatus @default(UNREGISTERED)

  lastSeenAt  DateTime?
  ipAddress   String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  scans       Scan[]

  @@index([schoolId])
  @@map("attendance_devices")
}

// ─── Feature Flags ────────────────────────────────────────────────────────────

model FeatureFlag {
  id          String    @id @default(cuid())
  key         String    @unique
  enabled     Boolean   @default(false)
  description String?
  metadata    Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("feature_flags")
}

// ─── Trusted Scan Zone ────────────────────────────────────────────────────────

model TrustedScanZone {
  id          String    @id @default(cuid())
  schoolId    String?
  ipRange     String
  description String?
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("trusted_scan_zones")
}