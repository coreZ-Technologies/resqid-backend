// prisma/schema/core/token.prisma

model Token {
  id        String      @id @default(cuid())
  schoolId  String
  school    School      @relation(fields: [schoolId], references: [id])
  studentId String?
  student   Student?    @relation(fields: [studentId], references: [id])

  // Card identity
  uid       String      @unique  // physical NFC/QR UID
  cardType  CardType    @default(QR)
  status    TokenStatus @default(UNREGISTERED)

  // Scan code — AES-SIV encrypted, used in QR URL
  scanCode  String      @unique
  scanCodeHash String   @unique  // for lookup

  issuedAt  DateTime?
  revokedAt DateTime?
  revokedBy String?     // userId who revoked

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  scanLogs  ScanLog[]
  order     OrderItem?

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@map("tokens")
}

enum CardType {
  QR
  NFC
  COMBO
}

enum TokenStatus {
  UNREGISTERED
  ISSUED
  ACTIVE
  INACTIVE
  REVOKED
  LOST
}

// ─── Scan Log — every scan recorded here ─────────────────────────────────────

model ScanLog {
  id          String    @id @default(cuid())
  tokenId     String
  token       Token     @relation(fields: [tokenId], references: [id])
  schoolId    String

  scannedAt   DateTime  @default(now())
  result      ScanResult

  // Context
  ipAddress   String?
  city        String?
  device      String?
  os          String?
  isBot       Boolean   @default(false)

  @@index([tokenId])
  @@index([schoolId])
  @@index([scannedAt])
  @@map("scan_logs")
}

enum ScanResult {
  INVALID
  UNREGISTERED
  ISSUED
  INACTIVE
  REVOKED
  ACTIVE
}

// ─── Scan Rate Limit — feeds ipBlock middleware ───────────────────────────────

model ScanRateLimit {
  id             String   @id @default(cuid())
  identifier     String
  identifierType String   // IP | TOKEN
  count          Int      @default(0)
  blockCount     Int      @default(0)
  blockedReason  String?
  lastHit        DateTime @default(now())
  windowStart    DateTime @default(now())

  @@unique([identifier, identifierType])
  @@index([identifier])
  @@map("scan_rate_limits")
}// ─────────────────────────────────────────────────────────────
// token.prisma
//
// Physical and digital tokens assigned to a student.
// A single student can have multiple active tokens:
//   • RFID card   → used by the attendance module
//   • QR badge    → used by the emergency module
//   • NFC sticker → future expansion
//
// Every scan (attendance tap / emergency QR) references the token
// that was used, giving a full audit trail from hardware to record.
// ─────────────────────────────────────────────────────────────

// ─── Enums ──────────────────────────────────────────────────

enum TokenType {
  RFID
  QR
  NFC
}

enum TokenStatus {
  ACTIVE
  INACTIVE
  REVOKED
  LOST
  EXPIRED
}

// ─── Token ──────────────────────────────────────────────────

model Token {
  id          String      @id @default(cuid())

  // ── Ownership ─────────────────────────────────────────────
  studentId   String
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School      @relation(fields: [schoolId], references: [id])

  // ── Identifier ────────────────────────────────────────────
  type        TokenType
  rfidUid     String?     @unique   // e.g. "A1B2C3D4" – unique RFID hardware UID
  qrCode      String?     @unique   // e.g. "RESQID:STU-123" – unique QR payload

  // ── Lifecycle ─────────────────────────────────────────────
  status      TokenStatus @default(ACTIVE)
  issuedAt    DateTime    @default(now())
  expiresAt   DateTime?   // e.g. end of the school year
  revokedAt   DateTime?   // set when status becomes REVOKED or LOST
  revokedBy   String?     // User.id of the admin who revoked it

  // ── Human‑readable label ──────────────────────────────────
  label       String?     // "Main RFID Card", "Emergency QR Badge"

  // ── Extras ────────────────────────────────────────────────
  metadata    Json?       // batch number, hardware version, etc.

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // ── Relations ─────────────────────────────────────────────
  scans       Scan[]      // all scans that used this token

  @@index([studentId])
  @@index([schoolId, type])
  @@index([rfidUid])
  @@index([qrCode])
}