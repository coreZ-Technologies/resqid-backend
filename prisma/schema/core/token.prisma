// prisma/schema/core/token.prisma

model Token {
  id        String      @id @default(cuid())
  schoolId  String
  school    School      @relation(fields: [schoolId], references: [id])
  studentId String?
  student   Student?    @relation(fields: [studentId], references: [id])

  // Card identity
  uid       String      @unique  // physical NFC/QR UID
  cardType  CardType    @default(QR)
  status    TokenStatus @default(UNREGISTERED)

  // Scan code — AES-SIV encrypted, used in QR URL
  scanCode  String      @unique
  scanCodeHash String   @unique  // for lookup

  issuedAt  DateTime?
  revokedAt DateTime?
  revokedBy String?     // userId who revoked

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  scanLogs  ScanLog[]
  order     OrderItem?

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@map("tokens")
}

enum CardType {
  QR
  NFC
  COMBO
}

enum TokenStatus {
  UNREGISTERED
  ISSUED
  ACTIVE
  INACTIVE
  REVOKED
  LOST
}

// ─── Scan Log — every scan recorded here ─────────────────────────────────────

model ScanLog {
  id          String    @id @default(cuid())
  tokenId     String
  token       Token     @relation(fields: [tokenId], references: [id])
  schoolId    String

  scannedAt   DateTime  @default(now())
  result      ScanResult

  // Context
  ipAddress   String?
  city        String?
  device      String?
  os          String?
  isBot       Boolean   @default(false)

  @@index([tokenId])
  @@index([schoolId])
  @@index([scannedAt])
  @@map("scan_logs")
}

enum ScanResult {
  INVALID
  UNREGISTERED
  ISSUED
  INACTIVE
  REVOKED
  ACTIVE
}

// ─── Scan Rate Limit — feeds ipBlock middleware ───────────────────────────────

model ScanRateLimit {
  id             String   @id @default(cuid())
  identifier     String
  identifierType String   // IP | TOKEN
  count          Int      @default(0)
  blockCount     Int      @default(0)
  blockedReason  String?
  lastHit        DateTime @default(now())
  windowStart    DateTime @default(now())

  @@unique([identifier, identifierType])
  @@index([identifier])
  @@map("scan_rate_limits")
}