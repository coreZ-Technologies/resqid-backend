// =============================================================================
// prisma/schema/core/token.prisma — RESQID
// Physical and digital tokens assigned to students
// =============================================================================

enum TokenType {
  RFID
  QR
  NFC
  COMBO
}

enum TokenStatus {
  UNREGISTERED
  ISSUED
  ACTIVE
  INACTIVE
  REVOKED
  LOST
  EXPIRED
}

enum ScanResult {
  INVALID
  UNREGISTERED
  ISSUED
  INACTIVE
  REVOKED
  ACTIVE
  BLOCKED
  SUSPICIOUS
}

model Token {
  id          String      @id @default(cuid())

  studentId   String?
  student     Student?    @relation(fields: [studentId], references: [id], onDelete: SetNull)
  schoolId    String
  school      School      @relation(fields: [schoolId], references: [id])

  type        TokenType   @default(QR)
  rfidUid     String?     @unique
  qrCode      String?     @unique

  // AES-SIV encrypted scan code for QR URL
  scanCode    String?     @unique
  scanCodeHash String?    @unique

  status      TokenStatus @default(UNREGISTERED)
  issuedAt    DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  revokedBy   String?

  label       String?
  metadata    Json?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  scans       Scan[]
  scanLogs    ScanLog[]
  orderItem   OrderItem?

  @@index([studentId])
  @@index([schoolId, type])
  @@index([rfidUid])
  @@index([scanCodeHash])
  @@index([status])
  @@map("tokens")
}

// ─── Scan Log ─────────────────────────────────────────────────────────────────

model ScanLog {
  id          String     @id @default(cuid())
  tokenId     String
  token       Token      @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  schoolId    String

  scannedAt   DateTime   @default(now())
  result      ScanResult

  ipAddress   String?
  city        String?
  device      String?
  os          String?
  isBot       Boolean    @default(false)

  @@index([tokenId])
  @@index([schoolId])
  @@index([scannedAt])
  @@map("scan_logs")
}

// ─── Scan Rate Limit ──────────────────────────────────────────────────────────

model ScanRateLimit {
  id             String    @id @default(cuid())
  identifier     String
  identifierType String    // IP | TOKEN | DEVICE
  count          Int       @default(0)
  blockCount     Int       @default(0)
  blockedUntil   DateTime?
  blockedReason  String?
  lastHit        DateTime  @default(now())
  windowStart    DateTime  @default(now())
  metadata       Json?

  @@unique([identifier, identifierType])
  @@index([identifier])
  @@map("scan_rate_limits")
}