// =============================================================================
// prisma/schema/core/school.prisma — RESQID
// Core school (tenant) model
// =============================================================================

enum Board {
  ICSE
  CBSE
  WB_BOARD
  STATE_BOARD
  IB
  CAMBRIDGE
  OTHER
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
}

model School {
  id         String       @id @default(cuid())
  name       String
  code       String?      @unique

  // Board affiliation
  board      Board        @default(OTHER)

  // Address (structured)
  street     String?
  city       String?
  state      String?
  country    String?      @default("India")
  postalCode String?

  // Contact
  email      String?
  phone      String?
  website    String?
  logoUrl    String?

  // Timezone
  timezone   String       @default("Asia/Kolkata")

  // Subscription
  planId     String?
  plan       Plan?        @relation(fields: [planId], references: [id])
  status     SchoolStatus @default(TRIAL)

  // Feature toggles — {"emergency":true,"attendance":true,"timetable":false}
  features   Json         @default("{}")

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // Relations
  users               SchoolUser[]
  students            Student[]
  tokens              Token[]
  scans               Scan[]
  subscriptions       Subscription[]
  orders              Order[]
  attendanceDevices   AttendanceDevice[]
  announcements       Announcement[]
  messages            Message[]
  notifications       Notification[]

  @@map("schools")
}