// ─────────────────────────────────────────────────────────────
// school.prisma
// Core school (tenant) model.
//
// Every school has:
//   • a board affiliation (ICSE / CBSE / …) – used by timetable module
//   • a physical address (separate fields, not JSON) – used for geo‑fencing,
//     emergency location context, and communication
//   • a subscription plan & status – controls feature availability
//   • feature toggles – quick per‑school module on/off switches
// ─────────────────────────────────────────────────────────────

// ─── Enums ──────────────────────────────────────────────────

enum Board {
  ICSE
  CBSE
  WB_BOARD        // West Bengal Board
  STATE_BOARD     // generic state board
  IB
  CAMBRIDGE
  OTHER
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  SUSPENDED       // e.g. payment overdue
  TRIAL           // free trial period
}

// ─── School ─────────────────────────────────────────────────

model School {
  id        String       @id @default(cuid())
  name      String

  // ── Board (mandatory) ─────────────────────────────────────
  board     Board        @default(OTHER)

  // ── Address (structured, not JSON) ────────────────────────
  street    String?      // e.g. "12 Park Street"
  city      String?
  state     String?
  country   String?      @default("India")
  postalCode String?     // e.g. "700016"

  // ── Contact ───────────────────────────────────────────────
  email     String?
  phone     String?
  website   String?

  // ── Timezone (default India) ──────────────────────────────
  timezone  String       @default("Asia/Kolkata")

  // ── Subscription & billing ────────────────────────────────
  planId    String?
  plan      Plan?        @relation(fields: [planId], references: [id])
  status    SchoolStatus @default(TRIAL)

  // ── Feature toggles ───────────────────────────────────────
  // Example: {"emergency":true,"attendance":true,"timetable":true,"communication":false}
  features  Json         @default("{}")

  // ── Timestamps ────────────────────────────────────────────
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // ── Relations (models in other files) ─────────────────────
  users     User[]       // all users belonging to this school
  students  Student[]
  tokens    Token[]
  scans     Scan[]
}