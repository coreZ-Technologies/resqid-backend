// =============================================================================
// prisma/schema/core/schema.prisma — RESQID
// Generator + Datasource configuration
// prismaSchemaFolder auto-discovers all .prisma files in subdirectories
// =============================================================================

generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}