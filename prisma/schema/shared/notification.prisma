// notification.prisma — RESQID
// Shared notification models: logs, preferences
// =============================================================================

model Notification {
  id         String             @id @default(cuid())

  // Recipient — polymorphic (parent or school staff)
  parentId     String?
  schoolUserId String?

  parent       Parent?          @relation(fields: [parentId], references: [id])
  schoolUser   User?            @relation(fields: [schoolUserId], references: [id])

  schoolId     String?
  school       School?          @relation(fields: [schoolId], references: [id])

  title        String
  body         String
  type         String            // from EVENTS constants (e.g., 'EMERGENCY_TRIGGERED')

  data         Json?             // deep link payload (studentId, incidentId, etc.)

  channel      NotificationChannel
  status       NotificationStatus  @default(PENDING)

  sentAt       DateTime?
  readAt       DateTime?
  failReason   String?

  createdAt    DateTime          @default(now())

  @@index([parentId])
  @@index([schoolUserId])
  @@index([status])
  @@index([type])
  @@map("notifications")
}

model NotificationPreference {
  id           String  @id @default(cuid())
  parentId     String  @unique
  parent       Parent  @relation(fields: [parentId], references: [id])

  smsEnabled   Boolean @default(true)
  emailEnabled Boolean @default(false)
  pushEnabled  Boolean @default(true)

  // Per‑event preferences
  onScan          Boolean @default(true)
  onAttendance    Boolean @default(true)
  onEmergency     Boolean @default(true)
  onAnnouncement  Boolean @default(true)

  updatedAt    DateTime @updatedAt

  @@index([parentId])
  @@map("notification_preferences")
}
