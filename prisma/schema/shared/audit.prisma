// #file: prisma/schema/audit.prisma

// ─────────────────────────────────────────────────────────────
// audit.prisma
//
// Central audit log for all business‑level actions.
// Used by:
//   • auditLog helper         (src/shared/helpers/auditLogger.js)
//   • auditLog middleware     (src/middleware/logging/auditLog.middleware.js)
//   • Super Admin dashboard   (view audit trails per school)
//   • Compliance & security reports
//
// This model is intentionally **denormalised** – it stores the
// actor/role/target as strings so we can log actions even if the
// actor or target is later deleted. No FK constraints here.
// ─────────────────────────────────────────────────────────────

enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model AuditLog {
  id        String   @id @default(cuid())

  // ── What happened ─────────────────────────────────────────
  action    String   // e.g. "student.created" (see shared/constants/audit.js)
  severity  AuditSeverity @default(INFO)

  // ── Who did it ────────────────────────────────────────────
  actorId   String?  // id of the user (SuperAdmin, SchoolUser, ParentUser)
  actorType String?  // "super_admin" | "school_user" | "parent_user" | "system"

  // ── What was affected ─────────────────────────────────────
  targetId   String? // id of the affected entity (student, token, etc.)
  targetType String? // "Student" | "Token" | "School" | "EmergencyProfile" …

  // ── Tenant scope (null for Super Admin cross‑school actions) ─
  schoolId  String?

  // ── Network / device context ──────────────────────────────
  ip        String?
  device    String?  // "Mobile" | "Desktop" | "Tablet"
  os        String?
  browser   String?

  // ── Extra details ─────────────────────────────────────────
  metadata  Json?    // old/new values, reason, notes – anything

  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([action])
  @@index([actorId])
  @@index([severity])
}