// =============================================================================
// prisma/schema/shared/audit.prisma — RESQID
// Central audit log for all business-level actions
// =============================================================================

enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model AuditLog {
  id         String        @id @default(cuid())

  action     String
  severity   AuditSeverity @default(INFO)

  actorId    String?
  actorType  String?

  entity     String?
  entityId   String?
  oldValue   Json?
  newValue   Json?

  schoolId   String?

  ipAddress  String?
  userAgent  String?
  device     String?

  metadata   Json?

  createdAt  DateTime      @default(now())

  @@index([schoolId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([entity, entityId])
  @@index([severity])
  @@map("audit_logs")
}