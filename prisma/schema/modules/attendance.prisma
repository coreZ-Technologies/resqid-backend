// =============================================================================
// attendance.prisma — RESQID
// Module m3: Attendance tracking via RFID taps
// =============================================================================

// ── Session (e.g., morning/afternoon class block) ──────────────────────────
model AttendanceSession {
  id          String    @id @default(cuid())
  schoolId    String
  teacherId   String    // references User.id (role = TEACHER)
  classGrade  String
  section     String
  subject     String?

  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  isActive    Boolean   @default(true)

  records     AttendanceRecord[]
  taps        AttendanceTap[]

  // Relations
  school      School    @relation(fields: [schoolId], references: [id])
  teacher     User      @relation(fields: [teacherId], references: [id])

  @@index([schoolId])
  @@index([teacherId])
  @@index([isActive])
  @@map("attendance_sessions")
}

// ── Raw tap from RFID reader (before processing) ───────────────────────────
model AttendanceTap {
  id          String            @id @default(cuid())
  sessionId   String
  session     AttendanceSession @relation(fields: [sessionId], references: [id])
  studentId   String
  student     Student           @relation(fields: [studentId], references: [id])
  schoolId    String

  uidHash     String            // SHA-256 of NFC UID (privacy-safe)
  tappedAt    DateTime          @default(now())
  deviceId    String?
  processed   Boolean           @default(false)

  // Relations
  school      School            @relation(fields: [schoolId], references: [id])

  @@index([sessionId])
  @@index([studentId])
  @@index([processed])
  @@map("attendance_taps")
}

// ── Processed attendance record (one per student per session) ──────────────
model AttendanceRecord {
  id          String            @id @default(cuid())
  sessionId   String
  session     AttendanceSession @relation(fields: [sessionId], references: [id])
  studentId   String
  student     Student           @relation(fields: [studentId], references: [id])
  schoolId    String

  status      AttendanceStatus  @default(PRESENT)
  markedAt    DateTime          @default(now())
  markedBy    String?           // optional teacherId if manually overridden

  // Relations
  school      School            @relation(fields: [schoolId], references: [id])

  @@unique([sessionId, studentId])
  @@index([schoolId])
  @@index([studentId])
  @@map("attendance_records")
}

// ── Enum ───────────────────────────────────────────────────────────────────
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}