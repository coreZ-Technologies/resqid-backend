// =============================================================================
// prisma/schema/modules/attendance.prisma — RESQID
// Attendance sessions, taps, and records
// =============================================================================

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  HALF_DAY
}

model AttendanceSession {
  id          String    @id @default(cuid())
  schoolId    String
  teacherId   String
  grade       String
  section     String
  subject     String?

  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  isActive    Boolean   @default(true)

  records     AttendanceRecord[]
  taps        AttendanceTap[]

  @@index([schoolId])
  @@index([teacherId])
  @@index([isActive])
  @@map("attendance_sessions")
}

model AttendanceTap {
  id          String            @id @default(cuid())
  sessionId   String
  session     AttendanceSession @relation(fields: [sessionId], references: [id])
  studentId   String
  student     Student           @relation(fields: [studentId], references: [id])
  schoolId    String

  uidHash     String
  tappedAt    DateTime          @default(now())
  deviceId    String?
  processed   Boolean           @default(false)

  @@index([sessionId])
  @@index([studentId])
  @@index([processed])
  @@map("attendance_taps")
}

model AttendanceRecord {
  id          String            @id @default(cuid())
  sessionId   String
  session     AttendanceSession @relation(fields: [sessionId], references: [id])
  studentId   String
  student     Student           @relation(fields: [studentId], references: [id])
  schoolId    String

  status      AttendanceStatus  @default(PRESENT)
  markedAt    DateTime          @default(now())
  markedBy    String?

  @@unique([sessionId, studentId])
  @@index([schoolId])
  @@index([studentId])
  @@map("attendance_records")
}