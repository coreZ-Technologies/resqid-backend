// =============================================================================
// prisma/schema/modules/emergency.prisma — RESQID
// Emergency profile and contacts — displayed on QR scan
// =============================================================================

model EmergencyProfile {
  id         String   @id @default(cuid())
  studentId  String   @unique
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId   String

  bloodGroup   String?
  allergies    String[]
  medications  String[]
  conditions   String[]
  doctorName   String?
  doctorPhone  String?

  showBloodGroup   Boolean @default(true)
  showAllergies    Boolean @default(true)
  showMedications  Boolean @default(false)
  showContacts     Boolean @default(true)

  isComplete  Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts    EmergencyContact[]

  @@index([schoolId])
  @@map("emergency_profiles")
}

model EmergencyContact {
  id         String           @id @default(cuid())
  profileId  String
  profile    EmergencyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name       String
  phone      String
  relation   String
  isPrimary  Boolean          @default(false)
  priority   Int              @default(0)

  isActive   Boolean          @default(true)
  callEnabled    Boolean      @default(true)
  whatsappEnabled Boolean     @default(false)

  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([profileId])
  @@map("emergency_contacts")
}