// =============================================================================
// timetable.prisma — RESQID
// Module m1: Timetable management, teachers, subjects, periods, substitutions
// =============================================================================

model Teacher {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String?  @unique   // optional link to User (if teacher has login)
  name      String
  phone     String?
  subjectIds String[] // subjects they teach (Subject.code or Subject.id)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  periods        Period[]
  substitutions  Substitution[] @relation("SubstituteTeacher")

  // Relations
  school   School  @relation(fields: [schoolId], references: [id])
  user     User?   @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@map("teachers")
}

model Subject {
  id       String  @id @default(cuid())
  schoolId String
  name     String  // "Mathematics"
  code     String? // "MATH"

  periods  Period[]

  // Relations
  school   School  @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("subjects")
}

model Period {
  id          String   @id @default(cuid())
  schoolId    String
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])

  classGrade  String
  section     String
  dayOfWeek   Int      // 1=Mon 2=Tue ... 6=Sat
  startTime   String   // "09:00"
  endTime     String   // "09:45"

  isActive    Boolean  @default(true)

  substitutions Substitution[]

  // Relations
  school   School  @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([teacherId])
  @@index([classGrade, section])
  @@map("periods")
}

model Substitution {
  id              String   @id @default(cuid())
  schoolId        String
  periodId        String
  period          Period   @relation(fields: [periodId], references: [id])
  substituteId    String
  substitute      Teacher  @relation("SubstituteTeacher", fields: [substituteId], references: [id])

  date            DateTime
  reason          String?
  notifiedAt      DateTime?

  createdAt       DateTime @default(now())

  // Relations
  school   School  @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([date])
  @@map("substitutions")
}