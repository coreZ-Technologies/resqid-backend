{
  "version": "1.0.0",
  "description": "Backend data contract for QR Management page – token management, QR generation, download, and regeneration.",
  "endpoints": {
    "getTokens": {
      "method": "GET",
      "path": "/api/v1/qr/tokens",
      "description": "Fetch paginated list of QR tokens for the school (with student assignment status).",
      "queryParams": {
        "search": "string (optional, searches student_name, student_class, token_hash)",
        "status": "string (optional, values: ACTIVE, UNASSIGNED, ISSUED, INACTIVE, REVOKED, EXPIRED)",
        "limit": "number (default 50)",
        "offset": "number (default 0)"
      },
      "response": {
        "success": true,
        "data": {
          "tokens": [
            {
              "id": "string (e.g., tok_1)",
              "token_hash": "string (unique, e.g., QRABCD1234)",
              "status": "enum: ACTIVE, UNASSIGNED, ISSUED, INACTIVE, REVOKED, EXPIRED",
              "student_id": "string or null",
              "student_name": "string or null",
              "student_class": "string or null (e.g., '5A')",
              "student_section": "string or null (A-D)",
              "school_id": "string",
              "expires_at": "datetime (ISO 8601, nullable)",
              "created_at": "datetime (ISO)",
              "qr_asset": {
                "type": "object",
                "nullable": true,
                "properties": {
                  "id": "string",
                  "format": "enum: PNG, SVG, PDF",
                  "width_px": "number",
                  "height_px": "number",
                  "file_size_kb": "number",
                  "public_url": "string (presigned or public URL)",
                  "generated_at": "datetime (ISO)"
                }
              }
            }
          ],
          "pagination": {
            "total": "number",
            "limit": "number",
            "offset": "number"
          }
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "tokens": [
            {
              "id": "tok_1",
              "token_hash": "QRABCDEF12345678",
              "status": "ACTIVE",
              "student_id": "stu_1",
              "student_name": "Aarav Sharma",
              "student_class": "5A",
              "student_section": "A",
              "school_id": "sch_001",
              "expires_at": "2026-12-31T00:00:00Z",
              "created_at": "2026-01-15T10:30:00Z",
              "qr_asset": {
                "id": "qr_1",
                "format": "PNG",
                "width_px": 512,
                "height_px": 512,
                "file_size_kb": 45,
                "public_url": "https://storage.example.com/qr/abc123.png",
                "generated_at": "2026-01-15T10:35:00Z"
              }
            }
          ],
          "pagination": { "total": 20, "limit": 50, "offset": 0 }
        }
      }
    },
    "generateQR": {
      "method": "POST",
      "path": "/api/v1/qr/tokens/:tokenId/generate",
      "description": "Generate a new QR asset for a given token (PNG/SVG/PDF). Creates cloud storage file and returns asset metadata.",
      "pathParams": {
        "tokenId": "string (required)"
      },
      "requestBody": {
        "format": "enum: PNG, SVG, PDF (required)",
        "width": "number (required, e.g., 512)",
        "height": "number (required, e.g., 512)"
      },
      "response": {
        "success": true,
        "data": {
          "qr_asset": {
            "id": "string",
            "format": "enum",
            "width_px": "number",
            "height_px": "number",
            "file_size_kb": "number",
            "public_url": "string",
            "generated_at": "datetime"
          }
        }
      }
    },
    "regenerateQR": {
      "method": "POST",
      "path": "/api/v1/qr/tokens/:tokenId/regenerate",
      "description": "Regenerate (overwrite) the existing QR asset for a token, using the same format/dimensions as the previous asset.",
      "pathParams": {
        "tokenId": "string (required, must have existing qr_asset)"
      },
      "response": "Same as generateQR"
    },
    "getStats": {
      "method": "GET",
      "path": "/api/v1/qr/stats",
      "description": "Get summary statistics for the school (students with tokens, QR generated, active tokens).",
      "response": {
        "success": true,
        "data": {
          "studentsWithTokens": "number (tokens assigned to a student)",
          "qrGenerated": "number (tokens with non-null qr_asset and assigned to student)",
          "activeTokens": "number (status = ACTIVE and assigned to student)"
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "studentsWithTokens": 150,
          "qrGenerated": 142,
          "activeTokens": 148
        }
      }
    },
    "getFilterOptions": {
      "method": "GET",
      "path": "/api/v1/qr/filter-options",
      "description": "Available token statuses for filter dropdown.",
      "response": {
        "success": true,
        "data": {
          "statuses": ["ACTIVE", "UNASSIGNED", "ISSUED", "INACTIVE", "REVOKED", "EXPIRED"]
        }
      }
    },
    "downloadQR": {
      "method": "GET",
      "path": "/api/v1/qr/tokens/:tokenId/download",
      "description": "Redirect to the public URL of the QR asset (or proxy the file) for download.",
      "pathParams": { "tokenId": "string" },
      "queryParams": { "format": "enum (PNG, SVG, PDF) – optional, if omitted uses existing asset's format" },
      "response": "File download (binary stream) or redirect to cloud URL"
    },
    "assignTokenToStudent": {
      "method": "PATCH",
      "path": "/api/v1/qr/tokens/:tokenId/assign",
      "description": "Assign an unassigned token to a student (needed for UI flow, but frontend may redirect to student page).",
      "requestBody": {
        "studentId": "string (required)",
        "studentName": "string (optional, can be fetched by backend)"
      },
      "response": {
        "success": true,
        "data": {
          "token": "object (updated token with student fields)"
        }
      }
    }
  },
  "enums": {
    "TokenStatus": ["ACTIVE", "UNASSIGNED", "ISSUED", "INACTIVE", "REVOKED", "EXPIRED"],
    "QRFormat": ["PNG", "SVG", "PDF"]
  },
  "fieldNotes": {
    "token_hash": "Should be a unique, non‑guessable string (e.g., random alphanumeric). Frontend masks it for display (first 4 + last 4).",
    "qr_asset.public_url": "Pre‑signed URL or publicly accessible cloud storage URL. Frontend uses it to display and download.",
    "qr_asset.format": "Must match one of the QRFormat enum.",
    "student_class": "Can be a string like '5A' (class + section) – but the frontend splits class and section when displaying. Backend may store combined or separate fields; UI uses student_class + student_section."
  }
}