{
  "moduleName": "Notifications",
  "description": "Manage and send notifications to parents via multiple channels (email, SMS, push, WhatsApp). Track delivery status, read rates, and filter history.",
  "dataModels": {
    "notification": {
      "id": "string",
      "title": "string",
      "message": "string (or body)",
      "type": "string (ANNOUNCEMENT, EMERGENCY, REMINDER, EVENT, ATTENDANCE, GENERAL)",
      "channel": "string (email, sms, push, whatsapp)",
      "status": "string (sent, delivered, read, failed)",
      "priority": "string (normal, high)",
      "sentBy": "string (user or 'System')",
      "sentAt": "string (ISO datetime)",
      "createdAt": "string (ISO datetime)",
      "scheduledFor": "string (optional)",
      "recipients": {
        "total": "number",
        "delivered": "number",
        "read": "number",
        "failed": "number"
      }
    },
    "notificationPreferences": {
      "email": "boolean",
      "sms": "boolean",
      "push": "boolean",
      "whatsapp": "boolean"
    },
    "recipientType": {
      "id": "string (all, class, section, individual)",
      "label": "string",
      "icon": "string",
      "count": "number"
    },
    "channelConfig": {
      "id": "string (email, sms, push, whatsapp)",
      "label": "string",
      "icon": "string",
      "color": "string"
    }
  },
  "keyMetrics": {
    "totalSent": "number (sum of recipients.total)",
    "totalDelivered": "number (sum of recipients.delivered)",
    "totalRead": "number (sum of recipients.read)",
    "avgOpenRate": "string (percentage, calculated as totalRead/totalDelivered * 100)"
  },
  "uiComponents": {
    "mainComponents": [
      "StatCard",
      "NotificationCard",
      "SendNotificationModal",
      "NotificationDetailsModal"
    ],
    "sharedComponentsUsed": [],
    "customHooks": ["useCallback", "useState", "useEffect"],
    "iconsUsed": [
      "Bell", "Send", "Mail", "Smartphone", "Users", "Filter", "Search",
      "CheckCircle", "XCircle", "Clock", "Eye", "Trash2", "RefreshCw",
      "MessageSquare", "TrendingUp", "Download", "Calendar", "Plus",
      "ChevronLeft", "ChevronRight", "MoreVertical", "Copy", "Share2",
      "BarChart3", "PieChart", "AlertCircle", "Globe", "Zap", "Settings",
      "UserCheck", "UserX", "Loader2", "FilterX", "Check", "X", "Edit2", "User",
      "Megaphone", "GraduationCap", "BookOpen"
    ]
  },
  "actionsAndRoutes": {
    "fetchNotifications": "GET /api/notifications (via lib/api)",
    "markAllRead": "API call to mark all notifications read",
    "sendNotification": "POST /api/notifications (mock in component)",
    "resendNotification": "retry failed notification",
    "deleteNotification": "DELETE /api/notifications/:id",
    "viewDetails": "open modal",
    "filter": "by type, status, date range, search",
    "pagination": "client-side slicing"
  },
  "dependencies": {
    "apiFunctions": [
      "getNotifications",
      "getUnreadNotificationCount",
      "markNotificationRead",
      "markAllNotificationsRead",
      "getNotificationPreferences",
      "updateNotificationPreferences"
    ],
    "apiModulePath": "@/lib/api",
    "utilityLibraries": ["@/lib/utils (cn)"],
    "reactHooks": ["useState", "useEffect", "useCallback"]
  },
  "monitorDashboardSuggestions": {
    "widgets": [
      {
        "type": "kpi",
        "title": "Notification Stats",
        "metrics": ["Total Sent", "Delivered", "Read", "Open Rate"]
      },
      {
        "type": "table",
        "title": "Recent Notifications (with delivery status)",
        "columns": ["Title", "Type", "Channel", "Status", "Delivered/Total", "Read Rate"]
      },
      {
        "type": "chart",
        "title": "Notifications by Type",
        "chartType": "pie",
        "dataSource": "group by type"
      },
      {
        "type": "chart",
        "title": "Delivery Rate Trend (last 7 days)",
        "chartType": "line",
        "metrics": ["sent", "delivered", "read"]
      },
      {
        "type": "alert",
        "title": "Failed Notifications",
        "condition": "status = 'failed' and retries > 0",
        "action": "highlight for admin review"
      },
      {
        "type": "topChannels",
        "title": "Channel Usage",
        "dataSource": "aggregate by channel.id"
      }
    ],
    "alertTriggers": [
      "Delivery rate drops below 90% for any notification",
      "High priority notification has read rate < 50% after 1 hour",
      "More than 5 failed notifications in last hour",
      "Scheduled notification not sent after scheduled time"
    ],
    "realTimeNeeds": [
      "WebSocket/SSE for live delivery status updates",
      "Push notification to admin when a high-priority notification fails"
    ]
  },
  "importantFilesForMonitoring": {
    "frontend": [
      "app/(school)/school/notifications/page.jsx",
      "lib/api.js (for notification API calls)"
    ],
    "backendIntegration": {
      "apiEndpointsInferred": [
        "GET /api/notifications?page=1&limit=10",
        "POST /api/notifications",
        "PATCH /api/notifications/:id/read",
        "PATCH /api/notifications/read-all",
        "DELETE /api/notifications/:id",
        "POST /api/notifications/:id/resend",
        "GET /api/notifications/preferences",
        "PUT /api/notifications/preferences"
      ],
      "webhooks": [
        "Delivery receipt from SMS/email/push provider → update notification status"
      ]
    }
  }
}