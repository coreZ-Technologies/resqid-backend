{
  "moduleName": "Emergency Management",
  "description": "Student emergency profiles, medical conditions, contacts, incident logging, and quick alert actions for school safety.",
  "dataModels": {
    "studentEmergencyProfile": {
      "id": "string (e.g., RQ-0001-00000001)",
      "studentId": "string (e.g., STU0001)",
      "name": "string",
      "class": "string (e.g., 9A)",
      "rollNo": "string",
      "dob": "string (YYYY-MM-DD)",
      "bloodGroup": "string (A+, A-, B+, B-, O+, O-, AB+, AB-)",
      "photo": "null or URL",
      "medicalConditions": "array of strings",
      "allergies": "array of strings",
      "medications": "array of strings",
      "doctorName": "string",
      "doctorPhone": "string",
      "parents": [
        {
          "relation": "string",
          "name": "string",
          "phone": "string",
          "alternatePhone": "null or string",
          "isReachable": "boolean"
        }
      ],
      "emergencyContacts": [
        {
          "relation": "string",
          "name": "string",
          "phone": "string"
        }
      ],
      "address": "string",
      "insuranceNo": "string",
      "notes": "string",
      "hasHighRisk": "boolean",
      "lastScanned": "string (ISO datetime)"
    },
    "incident": {
      "id": "string",
      "studentName": "string",
      "studentId": "string",
      "class": "string",
      "type": "string (Medical, Injury, Behavioral, Mental Health, Other)",
      "severity": "string (High, Medium, Low, Critical)",
      "time": "string (relative, e.g., '2 hours ago')",
      "status": "string (Resolved, Closed, Open)",
      "description": "string"
    }
  },
  "keyMetrics": {
    "totalStudents": "number (48 in mock)",
    "highRiskStudents": "number (based on hasHighRisk flag)",
    "incidentsToday": "number (0 in mock)",
    "resolvedIncidents": "number (3 in mock)",
    "systemStatus": "Active (with pulse indicator)"
  },
  "uiComponents": {
    "subComponents": [
      "BloodBadge",
      "RiskBadge",
      "SeverityDot",
      "ContactCard",
      "MedicalTag",
      "EmptyState",
      "StudentSearchPanel",
      "EmergencyProfile",
      "LogIncidentModal",
      "RecentIncidents",
      "StatsBar"
    ],
    "sharedComponentsUsed": [],
    "customHooks": [],
    "iconsUsed": [
      "Search", "AlertTriangle", "Phone", "Heart", "Droplets", "User",
      "ChevronDown", "ChevronRight", "X", "Clock", "MapPin", "Shield",
      "Zap", "Activity", "FileText", "CheckCircle", "XCircle",
      "PhoneCall", "MessageSquare", "Navigation", "Bell", "Filter",
      "RefreshCw", "Eye", "ClipboardList", "Siren", "UserCheck",
      "Ambulance", "BookOpen", "CalendarDays", "Hash", "AlertCircle",
      "Radio", "Wifi", "WifiOff", "ChevronUp", "Loader2", "Copy", "ExternalLink"
    ]
  },
  "actionsAndRoutes": {
    "studentSelection": "Search by name/ID/class; filter by class and risk level",
    "emergencyProfile": {
      "alertAll": "Broadcast emergency alert to all contacts (mock)",
      "callParents": "Initiate phone call to primary parent",
      "callAmbulance": "Open phone dialer for 108",
      "logIncident": "Open modal to record new incident",
      "copyStudentId": "Copy student ID to clipboard",
      "openMaps": "Open Google Maps with student address",
      "sendSMS": "Send emergency SMS to individual contact (mock)",
      "bulkNotify": "Send emergency SMS to all contacts (mock)"
    },
    "incidentLogging": {
      "openModal": "from profile or incidents tab",
      "submit": "Save incident with type, severity, description, action taken"
    },
    "recentIncidents": "Click incident to select that student",
    "emergencyNumbers": "Click to call 108, 100, 101"
  },
  "dependencies": {
    "mockData": "Internal mockStudents and mockIncidents arrays",
    "utilityLibraries": [
      "@/lib/utils (cn)",
      "react (useState, useEffect, useRef)"
    ],
    "externalPackages": [
      "lucide-react"
    ]
  },
  "monitorDashboardSuggestions": {
    "widgets": [
      {
        "type": "kpi",
        "title": "Emergency Overview",
        "metrics": ["Total Students", "High Risk Students", "Open Incidents", "Resolved Today"]
      },
      {
        "type": "list",
        "title": "High Risk Students (Require Immediate Attention)",
        "dataSource": "filtered by hasHighRisk=true",
        "fields": ["Name", "Class", "Medical Conditions", "Last Scanned"]
      },
      {
        "type": "table",
        "title": "Recent Incidents (Last 7 Days)",
        "dataSource": "mockIncidents sorted by time",
        "columns": ["Student", "Type", "Severity", "Status", "Time"]
      },
      {
        "type": "chart",
        "title": "Incidents by Type",
        "chartType": "pie",
        "dataSource": "aggregated from incidents"
      },
      {
        "type": "alert",
        "title": "Emergency Alerts",
        "conditions": [
          "Student with high-risk condition not scanned in > 3 days",
          "Multiple incidents for same student within 24 hours",
          "Parent unreachable flag toggled (isReachable = false)"
        ]
      }
    ],
    "alertTriggers": [
      "High-risk student marked as absent unexpectedly",
      "Emergency alert broadcast via 'Alert All' button",
      "Incident logged with severity 'High' or 'Critical'",
      "Failed to reach any parent contact for high-risk student"
    ],
    "realTimeNeeds": [
      "Live scanning events to update 'Last Scanned' field",
      "Push notification to admin when emergency alert is triggered",
      "WebSocket for incident log updates across multiple admin screens"
    ]
  },
  "importantFilesForMonitoring": {
    "frontend": [
      "app/(school)/school/emergency/page.jsx",
      "components/shared/StatusBadge.jsx (if used anywhere else; not directly in this file)",
      "lib/utils.js (for cn function)"
    ],
    "backendIntegration": {
      "apiEndpointsInferred": [
        "GET /api/emergency/students",
        "GET /api/emergency/students/:id",
        "POST /api/emergency/alert",
        "POST /api/emergency/incidents",
        "GET /api/emergency/incidents",
        "POST /api/emergency/contacts/sms"
      ],
      "webhooks": [
        "SOS button press from parent app → instant alert to school admin dashboard",
        "Low battery or offline status from RFID device → trigger maintenance alert"
      ]
    }
  },
  "sampleMockDataStructures": {
    "studentProfile": {
      "id": "RQ-0001-00000001",
      "studentId": "STU0001",
      "name": "Arjun Sharma",
      "class": "9A",
      "bloodGroup": "A+",
      "medicalConditions": ["Asthma"],
      "allergies": [],
      "hasHighRisk": true,
      "parents": [
        { "relation": "Father", "name": "Arjun Sharma Sr.", "phone": "+91 98XXXXXXXX", "isReachable": true }
      ],
      "lastScanned": "2026-06-05T10:30:00.000Z"
    },
    "incident": {
      "id": "INC001",
      "studentName": "Arjun Sharma",
      "type": "Medical",
      "severity": "High",
      "time": "2 hours ago",
      "status": "Resolved",
      "description": "Asthma attack during PT period. Inhaler administered."
    }
  }
}