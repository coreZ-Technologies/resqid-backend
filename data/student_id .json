    "updateEmergencyVisibility": {
      "method": "PATCH",
      "path": "/api/students/:studentId/emergency-visibility",
      "description": "Update the emergency QR profile visibility setting (PUBLIC, MINIMAL, HIDDEN).",
      "requestBody": {
        "visibility": "enum: PUBLIC, MINIMAL, HIDDEN (required)"
      },
      "response": {
        "success": true,
        "data": {
          "emergencyVisibility": "string"
        }
      }
    },
    "downloadQrCode": {
      "method": "GET",
      "path": "/api/students/:studentId/qr",
      "description": "Download the student's QR code image (PNG).",
      "response": "PNG image file (binary) or redirect to signed URL."
    },
    "generateReportCard": {
      "method": "POST",
      "path": "/api/students/:studentId/report-card",
      "description": "Trigger generation of student's report card (PDF). Returns job ID or direct download.",
      "response": {
        "success": true,
        "data": {
          "jobId": "string",
          "downloadUrl": "string (optional, if ready)"
        }
      }
    },
    "sendMessageToParents": {
      "method": "POST",
      "path": "/api/students/:studentId/message",
      "description": "Send a message to all primary contacts of the student (SMS/email/push).",
      "requestBody": {
        "subject": "string (optional)",
        "message": "string (required)",
        "channel": "enum: email, sms, push (optional, default email)"
      },
      "response": {
        "success": true,
        "message": "Message sent"
      }
    }
  },
  "enums": {
    "Gender": ["MALE", "FEMALE", "OTHER"],
    "StudentStatus": ["Active", "Inactive", "Graduated", "Transferred"],
    "EmergencyVisibility": ["PUBLIC", "MINIMAL", "HIDDEN"],
    "Relationship": ["Father", "Mother", "Guardian", "Other"]
  },
  "fieldNotes": {
    "age": "Can be computed from dateOfBirth on frontend; optional in API response.",
    "qrCodeId": "Unique identifier for the student's QR code; used in emergency profile display.",
    "emergencyVisibility": "Determines what information is shown when the student's QR code is scanned in an emergency.",
    "recentActivity.status": "Free-text status (e.g., 'Present', 'Pending', 'Completed') used for display.",
    "documents.size": "Human-readable file size (e.g., '1.2 MB')."
  }
}