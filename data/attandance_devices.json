{
  "version": "1.0.0",
  "description": "Backend data contract for RFID Devices page – provides device stats, device list with filters, device details, recent activity, and device management actions.",
  "endpoints": {
    "getStats": {
      "method": "GET",
      "path": "/api/v1/rfid/stats",
      "description": "Get KPI statistics for the RFID dashboard.",
      "response": {
        "success": true,
        "data": {
          "totalDevices": "number",
          "onlineCount": "number",
          "offlineCount": "number",
          "faultyCount": "number",
          "todayScans": "number"
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "totalDevices": 8,
          "onlineCount": 6,
          "offlineCount": 1,
          "faultyCount": 1,
          "todayScans": 847
        }
      }
    },
    "getDevices": {
      "method": "GET",
      "path": "/api/v1/rfid/devices",
      "description": "Fetch paginated list of RFID devices with filters and search.",
      "queryParams": {
        "page": "number (default 1)",
        "limit": "number (default 20)",
        "status": "string (optional, values: online, offline, faulty)",
        "zone": "string (optional, values: Entry, Classroom, Library, Outdoor, Indoor)",
        "search": "string (optional, searches name, id, location)",
        "sortBy": "string (optional, default name asc, e.g., name, status, todayScans)"
      },
      "response": {
        "success": true,
        "data": {
          "devices": [
            {
              "id": "string (e.g., RFID-001)",
              "name": "string",
              "location": "string",
              "zone": "enum: Entry, Classroom, Library, Outdoor, Indoor",
              "status": "enum: online, offline, faulty",
              "ipAddress": "string",
              "macAddress": "string",
              "firmware": "string (e.g., v3.2.1)",
              "battery": "number (0-100, nullable if wired)",
              "signal": "number (0-100)",
              "todayScans": "number",
              "totalScans": "number",
              "lastSeen": "string (relative or absolute timestamp)",
              "lastPing": "string",
              "installedOn": "string (date)",
              "type": "string (e.g., Gate Scanner, Classroom Reader, Outdoor Reader)",
              "model": "string (e.g., RESQID GS-200)",
              "issue": "string (optional, only for offline/faulty devices)"
            }
          ],
          "pagination": {
            "currentPage": 1,
            "totalPages": 1,
            "totalItems": 8,
            "itemsPerPage": 20
          }
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "devices": [
            {
              "id": "RFID-001",
              "name": "Main Entrance Scanner",
              "location": "Main Gate",
              "zone": "Entry",
              "status": "online",
              "ipAddress": "192.168.1.101",
              "macAddress": "A4:CF:12:88:01:FF",
              "firmware": "v3.2.1",
              "battery": null,
              "signal": 98,
              "todayScans": 312,
              "totalScans": 42810,
              "lastSeen": "Just now",
              "lastPing": "2s ago",
              "installedOn": "12 Jan 2025",
              "type": "Gate Scanner",
              "model": "RESQID GS-200"
            }
          ],
          "pagination": {
            "currentPage": 1,
            "totalPages": 1,
            "totalItems": 8,
            "itemsPerPage": 20
          }
        }
      }
    },
    "getDeviceById": {
      "method": "GET",
      "path": "/api/v1/rfid/devices/:id",
      "description": "Get full details of a single device (for detail panel). Response is same as device object in list.",
      "response": {
        "success": true,
        "data": "Device object (same as above)"
      }
    },
    "updateDeviceFirmware": {
      "method": "POST",
      "path": "/api/v1/rfid/devices/:id/firmware",
      "description": "Trigger firmware update for a device.",
      "requestBody": {
        "firmwareVersion": "string (optional, backend may use latest available)"
      },
      "response": {
        "success": true,
        "data": {
          "id": "string",
          "firmware": "string (new version)",
          "status": "enum: updating, pending, failed",
          "message": "string"
        }
      }
    },
    "restartDevice": {
      "method": "POST",
      "path": "/api/v1/rfid/devices/:id/restart",
      "description": "Send restart command to the device.",
      "response": {
        "success": true,
        "data": {
          "id": "string",
          "message": "Restart command sent",
          "status": "pending"
        }
      }
    },
    "deleteDevice": {
      "method": "DELETE",
      "path": "/api/v1/rfid/devices/:id",
      "description": "Remove a device from the system (typically allowed only for offline/faulty devices).",
      "response": {
        "success": true,
        "message": "Device removed successfully"
      }
    },
    "getFilterOptions": {
      "method": "GET",
      "path": "/api/v1/rfid/filter-options",
      "description": "Get available filter values for statuses and zones based on existing data.",
      "response": {
        "success": true,
        "data": {
          "statuses": ["online", "offline", "faulty"],
          "zones": ["Entry", "Classroom", "Library", "Outdoor", "Indoor"]
        }
      }
    },
    "exportDevices": {
      "method": "GET",
      "path": "/api/v1/rfid/devices/export",
      "description": "Export filtered devices as CSV (same query params as getDevices, no pagination).",
      "queryParams": "Same as getDevices (page, limit ignored)",
      "response": "CSV file download with columns: id, name, location, zone, status, ipAddress, macAddress, firmware, battery, signal, todayScans, totalScans, lastSeen, installedOn, type, model"
    },
    "getRecentActivity": {
      "method": "GET",
      "path": "/api/v1/rfid/recent-activity",
      "description": "Fetch recent events from all RFID devices (for the activity feed on the page).",
      "queryParams": {
        "limit": "number (default 10, max 50)"
      },
      "response": {
        "success": true,
        "data": [
          {
            "deviceId": "string",
            "deviceName": "string",
            "event": "string (e.g., Scan, Went Offline, Anomaly Scan, Firmware Error)",
            "student": "string (optional, student name if applicable)",
            "time": "datetime (ISO 8601)",
            "status": "enum: success, warning, error"
          }
        ]
      },
      "exampleResponse": {
        "success": true,
        "data": [
          {
            "deviceId": "RFID-001",
            "deviceName": "Main Entrance Scanner",
            "event": "Scan",
            "student": "Priya Sharma",
            "time": "2026-05-24T08:02:00",
            "status": "success"
          }
        ]
      }
    }
  },
  "fieldNotes": {
    "battery": "null for wired devices, 0-100 for battery-powered",
    "signal": "0-100 (0 = no signal)",
    "lastSeen": "Backend may return ISO timestamp; frontend converts to relative or absolute string",
    "lastPing": "String like '2s ago', can be computed from lastSeen time",
    "issue": "Only provided for devices with status 'offline' or 'faulty' that have a known problem",
    "firmware": "Versions may be compared to latest to show 'Update available' on frontend"
  }
}