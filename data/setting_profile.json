{
  "version": "1.0.0",
  "description": "Backend data contract for Profile page – admin profile management, module permissions, recent activity, active sessions, and account deletion.",
  "endpoints": {
    "getCurrentUser": {
      "method": "GET",
      "path": "/api/auth/me",
      "description": "Get current authenticated admin user's profile and associated school stats.",
      "response": {
        "success": true,
        "data": {
          "user": {
            "id": "string",
            "name": "string",
            "email": "string",
            "phone": "string",
            "role": "enum: admin, superadmin",
            "schoolId": "string",
            "schoolName": "string",
            "schoolCode": "string",
            "plan": "enum: Basic, Professional, Enterprise",
            "memberSince": "string (e.g., 'January 2024')",
            "avatar": "string or null (URL)"
          },
          "stats": {
            "students": "number",
            "staff": "number",
            "classes": "number"
          }
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "user": {
            "id": "adm_001",
            "name": "Animesh Karan",
            "email": "admin@springdaleschool.in",
            "phone": "+91 98765 43210",
            "role": "admin",
            "schoolId": "sch_001",
            "schoolName": "Springdale Public School",
            "schoolCode": "SPR-2024-K7",
            "plan": "Professional",
            "memberSince": "January 2024",
            "avatar": null
          },
          "stats": {
            "students": 847,
            "staff": 62,
            "classes": 24
          }
        }
      }
    },
    "updateCurrentUser": {
      "method": "PATCH",
      "path": "/api/auth/me",
      "description": "Update admin profile information (name, email, phone).",
      "requestBody": {
        "name": "string (optional)",
        "email": "string (optional, must be unique)",
        "phone": "string (optional)"
      },
      "response": {
        "success": true,
        "data": "Updated user object (same as getCurrentUser)"
      }
    },
    "getModulePermissions": {
      "method": "GET",
      "path": "/api/schools/:schoolId/permissions",
      "description": "Get list of module permissions available and their current status for the admin (or for the school).",
      "response": {
        "success": true,
        "data": {
          "permissions": [
            {
              "id": "string (module id)",
              "label": "string (display name)",
              "description": "string",
              "default": "boolean (default value for new admins)",
              "granted": "boolean (current status for this admin)"
            }
          ]
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "permissions": [
            {
              "id": "dashboard",
              "label": "Dashboard",
              "description": "Full overview access",
              "default": true,
              "granted": true
            },
            {
              "id": "communication",
              "label": "Communication",
              "description": "Broadcast messages",
              "default": false,
              "granted": false
            }
          ]
        }
      }
    },
    "updateModulePermissions": {
      "method": "PATCH",
      "path": "/api/schools/:schoolId/permissions",
      "description": "Update which modules are granted to the current admin (or to a specific role).",
      "requestBody": {
        "permissions": {
          "dashboard": "boolean",
          "students": "boolean"
        }
      },
      "response": {
        "success": true,
        "message": "Permissions updated",
        "data": "Updated permissions object"
      }
    },
    "getRecentActivity": {
      "method": "GET",
      "path": "/api/activity-logs",
      "description": "Fetch recent admin actions (used for the activity log in profile).",
      "queryParams": {
        "limit": "number (default 5, max 20)",
        "offset": "number (default 0)"
      },
      "response": {
        "success": true,
        "data": {
          "logs": [
            {
              "icon": "string (icon identifier, e.g., 'UserPlus', 'AlertTriangle')",
              "title": "string",
              "meta": "string (context and relative time)"
            }
          ],
          "pagination": {
            "total": "number",
            "limit": "number",
            "offset": "number"
          }
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "logs": [
            {
              "icon": "UserPlus",
              "title": "Added 3 new students",
              "meta": "Class 9B · 2 hours ago"
            }
          ],
          "pagination": { "total": 5, "limit": 5, "offset": 0 }
        }
      }
    },
    "getActiveSessions": {
      "method": "GET",
      "path": "/api/auth/sessions",
      "description": "Get list of active sessions for the current admin.",
      "response": {
        "success": true,
        "data": {
          "sessions": [
            {
              "id": "string",
              "device": "string (e.g., 'Chrome — Windows 11')",
              "meta": "string (location and time)",
              "current": "boolean",
              "icon": "enum: Laptop, Smartphone, Tablet"
            }
          ]
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "sessions": [
            {
              "id": "sess_001",
              "device": "Chrome — Windows 11",
              "meta": "Kolkata, India · Just now",
              "current": true,
              "icon": "Laptop"
            }
          ]
        }
      }
    },
    "revokeSession": {
      "method": "DELETE",
      "path": "/api/auth/sessions/:sessionId",
      "description": "Terminate a specific session (cannot revoke current session).",
      "pathParams": { "sessionId": "string" },
      "response": {
        "success": true,
        "message": "Session revoked"
      }
    },
    "revokeAllOtherSessions": {
      "method": "POST",
      "path": "/api/auth/sessions/revoke-all",
      "description": "Terminate all sessions except the current one.",
      "response": {
        "success": true,
        "message": "All other sessions revoked"
      }
    },
    "deleteAdminAccount": {
      "method": "DELETE",
      "path": "/api/auth/account",
      "description": "Permanently delete the admin account (danger zone action). Requires confirmation with password or re-authentication.",
      "requestBody": {
        "confirm": "boolean (required, must be true)",
        "password": "string (required to confirm)"
      },
      "response": {
        "success": true,
        "message": "Account deleted successfully"
      }
    }
  },
  "enums": {
    "UserRole": ["admin", "superadmin"],
    "Plan": ["Basic", "Professional", "Enterprise"],
    "SessionIcon": ["Laptop", "Smartphone", "Tablet"]
  },
  "fieldNotes": {
    "permissions.granted": "Current status for the authenticated admin. The toggle UI updates this via the PATCH endpoint.",
    "recentActivity.icon": "Frontend maps this string to the corresponding Lucide icon component. Backend should return one of the expected icon names (e.g., 'UserPlus', 'AlertTriangle', 'CalendarCheck', 'Clock', 'Settings') or send an identifier that frontend can map.",
    "sessions.icon": "One of Laptop, Smartphone, Tablet; frontend uses to render the appropriate icon.",
    "deleteAdminAccount": "Highly destructive action; backend should require recent re‑authentication (e.g., ask for password again or verify OTP)."
  }
}