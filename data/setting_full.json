{
  "version": "1.0.0",
  "description": "Backend data contract for School Settings page – school profile, notification preferences, security settings (password, 2FA, sessions), and billing plan.",
  "endpoints": {
    "getSchoolProfile": {
      "method": "GET",
      "path": "/api/schools/:schoolId",
      "description": "Fetch school profile information (basic info, contact details, logo).",
      "response": {
        "success": true,
        "data": {
          "name": "string",
          "code": "string",
          "board": "string (e.g., 'CBSE', 'ICSE', 'IB', 'State Board', 'NIOS')",
          "address": "string",
          "phone": "string",
          "email": "string",
          "website": "string",
          "established": "string (year)",
          "type": "enum: Co-educational, Boys, Girls",
          "medium": "enum: English, Hindi, Bengali, Other",
          "logoUrl": "string (URL or null)"
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "name": "Springdale Public School",
          "code": "SPR-2024-K7",
          "board": "CBSE",
          "address": "42, Park Street, Kolkata, West Bengal - 700016",
          "phone": "+91 33 2229 4400",
          "email": "admin@springdaleschool.in",
          "website": "www.springdaleschool.in",
          "established": "1998",
          "type": "Co-educational",
          "medium": "English",
          "logoUrl": null
        }
      }
    },
    "updateSchoolProfile": {
      "method": "PATCH",
      "path": "/api/schools/:schoolId",
      "description": "Update school profile information (partial updates allowed).",
      "requestBody": {
        "name": "string (optional)",
        "board": "string (optional)",
        "address": "string (optional)",
        "phone": "string (optional)",
        "email": "string (optional)",
        "website": "string (optional)",
        "established": "string (optional)",
        "type": "enum (optional)",
        "medium": "enum (optional)"
      },
      "response": {
        "success": true,
        "data": "Updated school profile object"
      }
    },
    "uploadSchoolLogo": {
      "method": "POST",
      "path": "/api/schools/:schoolId/logo",
      "description": "Upload school logo image (PNG/JPG, max 2MB).",
      "requestBody": "multipart/form-data with field 'logo'",
      "response": {
        "success": true,
        "data": {
          "logoUrl": "string"
        }
      }
    },
    "getNotificationPreferences": {
      "method": "GET",
      "path": "/api/schools/:schoolId/notification-prefs",
      "description": "Get all notification preferences (per event type and channel).",
      "response": {
        "success": true,
        "data": {
          "preferences": [
            {
              "id": "string (e.g., 'emergency_alerts')",
              "label": "string",
              "description": "string",
              "channels": {
                "email": "boolean",
                "sms": "boolean",
                "push": "boolean"
              }
            }
          ],
          "digests": [
            {
              "id": "string (e.g., 'daily_attendance')",
              "label": "string",
              "description": "string",
              "enabled": "boolean"
            }
          ]
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "preferences": [
            {
              "id": "emergency_alerts",
              "label": "Emergency alerts",
              "description": "SOS triggers, drill notifications",
              "channels": { "email": true, "sms": true, "push": true }
            }
          ],
          "digests": [
            {
              "id": "daily_attendance",
              "label": "Daily attendance digest",
              "description": "Sent every morning at 8 AM",
              "enabled": true
            }
          ]
        }
      }
    },
    "updateNotificationPreferences": {
      "method": "PATCH",
      "path": "/api/schools/:schoolId/notification-prefs",
      "description": "Update notification preferences (channels per event type or digest toggles).",
      "requestBody": {
        "preferences": [
          {
            "id": "string",
            "channels": {
              "email": "boolean (optional)",
              "sms": "boolean (optional)",
              "push": "boolean (optional)"
            }
          }
        ],
        "digests": [
          {
            "id": "string",
            "enabled": "boolean"
          }
        ]
      },
      "response": {
        "success": true,
        "message": "Preferences updated"
      }
    },
    "changePassword": {
      "method": "POST",
      "path": "/api/auth/change-password",
      "description": "Change password for the authenticated admin user.",
      "requestBody": {
        "currentPassword": "string (required)",
        "newPassword": "string (required, min 8 chars)",
        "confirmPassword": "string (required)"
      },
      "response": {
        "success": true,
        "message": "Password changed successfully"
      },
      "errorResponses": {
        "400": { "message": "Invalid current password or mismatch" }
      }
    },
    "getSecuritySettings": {
      "method": "GET",
      "path": "/api/schools/:schoolId/security",
      "description": "Get security settings (2FA status, login alerts).",
      "response": {
        "success": true,
        "data": {
          "twoFactorEnabled": "boolean",
          "loginAlertsEnabled": "boolean"
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "twoFactorEnabled": false,
          "loginAlertsEnabled": true
        }
      }
    },
    "updateSecuritySettings": {
      "method": "PATCH",
      "path": "/api/schools/:schoolId/security",
      "description": "Update security settings (2FA, login alerts).",
      "requestBody": {
        "twoFactorEnabled": "boolean (optional)",
        "loginAlertsEnabled": "boolean (optional)"
      },
      "response": {
        "success": true,
        "data": "Updated security settings"
      }
    },
    "getActiveSessions": {
      "method": "GET",
      "path": "/api/auth/sessions",
      "description": "Get list of active sessions for the authenticated admin.",
      "response": {
        "success": true,
        "data": {
          "sessions": [
            {
              "id": "number or string",
              "device": "string (e.g., 'Chrome — Windows 11')",
              "meta": "string (location and time)",
              "current": "boolean",
              "icon": "enum: Laptop, Smartphone, Tablet"
            }
          ]
        }
      }
    },
    "revokeSession": {
      "method": "DELETE",
      "path": "/api/auth/sessions/:sessionId",
      "description": "Terminate a specific session (cannot revoke current session).",
      "pathParams": { "sessionId": "string" },
      "response": {
        "success": true,
        "message": "Session revoked"
      }
    },
    "revokeAllOtherSessions": {
      "method": "POST",
      "path": "/api/auth/sessions/revoke-all",
      "description": "Terminate all sessions except the current one.",
      "response": {
        "success": true,
        "message": "All other sessions revoked"
      }
    },
    "getBillingPlan": {
      "method": "GET",
      "path": "/api/billing/plan",
      "description": "Get current billing plan details (name, price, renewal, usage, features, upgrade options).",
      "response": {
        "success": true,
        "data": {
          "name": "string",
          "price": "string (formatted, e.g., '₹4,999')",
          "cycle": "string (e.g., 'per year')",
          "renewsOn": "string (date)",
          "students": "number",
          "studentLimit": "number",
          "features": ["string"],
          "upgrades": [
            {
              "label": "string",
              "plan": "string (e.g., 'Professional', 'Enterprise')"
            }
          ]
        }
      },
      "exampleResponse": {
        "success": true,
        "data": {
          "name": "Standard",
          "price": "₹4,999",
          "cycle": "per year",
          "renewsOn": "March 15, 2026",
          "students": 847,
          "studentLimit": 1000,
          "features": [
            "QR-based emergency ID cards",
            "Parent portal access",
            "Attendance & timetable modules",
            "Email & SMS notifications",
            "Reports & analytics"
          ],
          "upgrades": [
            { "label": "Emergency SOS alerts", "plan": "Professional" },
            { "label": "Parent communication broadcast", "plan": "Enterprise" },
            { "label": "Custom branding on ID cards", "plan": "Professional" }
          ]
        }
      }
    },
    "getInvoiceList": {
      "method": "GET",
      "path": "/api/billing/invoices",
      "description": "Get list of past invoices (for the school).",
      "queryParams": {
        "limit": "number (default 12)",
        "offset": "number (default 0)"
      },
      "response": {
        "success": true,
        "data": {
          "invoices": [
            {
              "id": "string",
              "date": "date (YYYY-MM-DD)",
              "amount": "string (formatted)",
              "status": "enum: paid, pending, overdue"
            }
          ],
          "pagination": { "total": "number", "limit": "number", "offset": "number" }
        }
      }
    },
    "downloadInvoice": {
      "method": "GET",
      "path": "/api/billing/invoices/:invoiceId/download",
      "description": "Download invoice PDF.",
      "pathParams": { "invoiceId": "string" },
      "response": "PDF file (binary)"
    }
  },
  "enums": {
    "Board": ["CBSE", "ICSE", "IB", "State Board", "NIOS"],
    "SchoolType": ["Co-educational", "Boys", "Girls"],
    "Medium": ["English", "Hindi", "Bengali", "Other"],
    "SessionIcon": ["Laptop", "Smartphone", "Tablet"],
    "InvoiceStatus": ["paid", "pending", "overdue"]
  },
  "fieldNotes": {
    "logoUrl": "Public URL to uploaded logo image.",
    "notificationPreferences.channels": "Each channel can be enabled/disabled independently per event type.",
    "digests": "Scheduled email summaries like daily attendance, weekly activity, monthly billing.",
    "twoFactorEnabled": "When true, user must provide OTP from authenticator app or SMS on login.",
    "loginAlertsEnabled": "When true, user receives email/push when a new login occurs.",
    "billing.studentLimit": "Soft limit for the current plan; usage bar is shown based on current students count.",
    "upgrades": "Features that are not included in the current plan, with required plan name."
  }
}