# +++++++++++++++++++++++++++++++++++
# + RESQID - coreZ Technologies LLD +
# + COMPLETE ENVIRONMENT VARIABLES  +
# +++++++++++++++++++++++++++++++++++


# SERVER
NODE_ENV=development
PORT=3000
API_URL=
TRUST_PROXY=1
TRUSTED_IPS=127.0.0.1,::1,10.0.0.1
CLOUDFLARE_ONLY=false


# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/resqid?schema=public
DIRECT_URL=postgresql://user:password@localhost:5432/resqid


# REDIS
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_KEY_PREFIX=resqid:
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_KEEP_ALIVE=300000


# JWT
JWT_ACCESS_SECRET=your-access-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRY=7d
JWT_ACCESS_EXPIRY_CUSTOM=30d


# CSRF & MAINTENANCE
CSRF_SECRET=your-csrf-secret-here
MAINTENANCE_BYPASS_SECRET=


# APPLICATION URLs
SUPER_ADMIN_URL=http://localhost:3001
SCHOOL_ADMIN_URL=http://localhost:3002
MOBILE_APP_SCHEME=resqid://
COOKIE_DOMAIN=.getresqid.in
SCAN_BASE_URL=https://scan.getresqid.in


# CLOUDFLARE R2 (Storage)
AWS_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=


# SMS (MSG91/2FACTOR)
SMS_AUTH_KEY=
SMS_OTP_TEMPLATE_ID=
SMS_EMERGENCY_TEMPLATE_ID=
SMS_ATTENDANCE_TEMPLATE_ID=
SMS_SENDER_ID=RESQID


# EMAIL (RESEND/BREVO/SES)
EMAIL_API_KEY=
EMAIL_FROM_EMAIL=noreply@getresqid.in
EMAIL_FROM_NAME=RESQID


# ENCRYPTION & HASHING
ENCRYPTION_KEY=
LOOKUP_HASH_SECRET=
TOKEN_HASH_SECRET=
SCAN_CODE_SECRET=


# BRANDING
RESQID_DEFAULT_LOGO_URL=https://getresqid.in/logo.png
BRAND_NAME=RESQID
BRAND_COLOR=#0284c7


# IP GEOLOCATION
IP_GEO_API_KEY=
IP_GEO_PROVIDER=ipapi


# LOGGING
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE_PATH=./logs


# SENTRY (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1


# GEO BLOCKING
BEHIND_CLOUDFLARE=false
BEHIND_CLOUDFRONT=false


# TOKEN / QR
TOKEN_VALIDITY_MONTHS=12
QR_DEFAULT_PX=512
QR_ERROR_CORRECTION=M


# RATE LIMITING
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUEST=100
OTP_IP_LIMIT=5
OTP_PHONE_LIMIT=3


# EXPO (Push Notifications)
EXPO_ACCESS_TOKEN=


# SERVICE PROVIDERS
EMAIL_PROVIDER=resend
SMS_PROVIDER=msg91
PUSH_PROVIDER=expo


# 🔴 ATTENDANCE DEVICE CONFIG
ATTENDANCE_DEVICE_API_KEY=
ATTENDANCE_DEVICE_SECRET=
ATTENDANCE_DEVICE_HEARTBEAT_INTERVAL=30
ATTENDANCE_SCAN_BATCH_SIZE=100
ATTENDANCE_SCAN_FLUSH_INTERVAL=60
ATTENDANCE_MAX_DEVICES_PER_SCHOOL=50


# 🔴 SCHOOL DEFAULTS
SCHOOL_DEFAULT_TIMEZONE=Asia/Kolkata
SCHOOL_DEFAULT_PERIODS=8
SCHOOL_DEFAULT_WORKING_DAYS=Mon,Tue,Wed,Thu,Fri,Sat
SCHOOL_DEFAULT_START_TIME=08:00
SCHOOL_DEFAULT_END_TIME=15:00
SCHOOL_TRIAL_DAYS=14
SCHOOL_MAX_STUDENTS_DEFAULT=500
SCHOOL_MAX_TEACHERS_DEFAULT=50


# 🔴 TEACHER DEFAULTS
TEACHER_DEFAULT_MAX_PERIODS_DAY=6
TEACHER_DEFAULT_MAX_PERIODS_WEEK=30
TEACHER_DEFAULT_MAX_CONSECUTIVE=3
TEACHER_AUTO_SUBSTITUTE=true
TEACHER_SUBSTITUTE_NOTICE_MINUTES=30


# 🔴 TIMETABLE SOLVER
TIMETABLE_SOLVER_TIMEOUT_MS=300000
TIMETABLE_SOLVER_MAX_BACKTRACKS=50000
TIMETABLE_SOLVER_MODE=class-by-class
TIMETABLE_GENERATE_CONCURRENCY=2
TIMETABLE_CRISIS_CONCURRENCY=5
TIMETABLE_VALIDATE_CONCURRENCY=3


# 🔴 WELLNESS ALERTS
WELLNESS_BURNOUT_THRESHOLD=80
WELLNESS_CONSECUTIVE_DAYS_THRESHOLD=6
WELLNESS_SENIOR_AGE=55
WELLNESS_CHECK_INTERVAL_DAYS=30


# 🔴 EMERGENCY
EMERGENCY_ALERT_TIMEOUT_SECONDS=30
EMERGENCY_ESCALATION_DELAY_MINUTES=5
EMERGENCY_MAX_CONTACTS_PER_STUDENT=5
EMERGENCY_DRILL_REMINDER_DAYS=90


# 🔴 BULLMQ WORKERS
WORKER_ROLE=all
ENABLE_PIPELINE_QUEUE=false
WORKER_CONCURRENCY_EMERGENCY=10
WORKER_CONCURRENCY_NOTIFICATION=5
WORKER_CONCURRENCY_ATTENDANCE=3
WORKER_CONCURRENCY_GENERATE=2
WORKER_CONCURRENCY_CRISIS=5
WORKER_CONCURRENCY_VALIDATE=3
WORKER_CONCURRENCY_SWAP=3
WORKER_CONCURRENCY_BULK=2


# 🔴 FEATURE FLAGS
FEATURE_TIMETABLE_ENABLED=true
FEATURE_ATTENDANCE_ENABLED=true
FEATURE_EMERGENCY_ENABLED=true
FEATURE_WELLNESS_ENABLED=true
FEATURE_BULK_UPLOAD_ENABLED=true
FEATURE_CRISIS_AUTO_RESOLVE=true
FEATURE_NOTIFICATIONS_ENABLED=true


# 🔴 FILE UPLOAD LIMITS
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_TYPES=xlsx,csv,xls
UPLOAD_MAX_ROWS_PER_BATCH=500


# 🔴 CACHE TTL
CACHE_SCHOOL_CONFIG_TTL=3600
CACHE_TEACHER_LIST_TTL=1800
CACHE_STUDENT_LIST_TTL=1800
CACHE_TIMETABLE_TTL=86400


# 🔴 PAGINATION DEFAULTS
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

# 🔴 MONITORING
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=false
SLOW_QUERY_THRESHOLD_MS=1000