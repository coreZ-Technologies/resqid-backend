        warn_big:
          '<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 3L2 20h20L12 3z" stroke="#ffb020" stroke-width="1.6" stroke-linejoin="round"/><path d="M12 10v5M12 17.5h.01" stroke="#ffb020" stroke-width="2" stroke-linecap="round"/></svg>',
        pending:
          '<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#4d8eff" stroke-width="1.6"/><path d="M12 7v5l3 3" stroke="#4d8eff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>',
        blood:
          '<svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 3C12 3 5 11.33 5 15.5a7 7 0 0014 0C19 11.33 12 3 12 3z" stroke="#ff3d3d" stroke-width="1.6" stroke-linejoin="round"/></svg>',
        gender:
          '<svg width="12" height="12" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="10" r="5" stroke="currentColor" stroke-width="1.6"/><path d="M12 15v6M9 18h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>',
        class_:
          '<svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 3L2 7l10 4 10-4-10-4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M2 17l10 4 10-4M2 12l10 4 10-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
      };

      // ── Renderers ───────────────────────────────────────────
      function footer() {
        return `<div class="footer"><div class="footer-brand"><div class="footer-dot"></div><span class="footer-name">RESQID</span></div><span class="footer-tagline">Emergency Identity · coreZ Technologies</span></div>`;
      }

      function renderStatus({ iconKey, iconClass, title, message, school }) {
        const schoolHtml = school ? `<p class="status-school">${esc(school.name || '')}</p>` : '';
        return `<div class="status-page"><div class="status-icon ${iconClass}">${I[iconKey]}</div><p class="status-title">${esc(title)}</p><p class="status-msg">${esc(message)}</p>${schoolHtml}${footer()}</div>`;
      }

      function renderSchoolStrip(school, code) {
        if (!school) return '';
        const logoUrl = fixCdnUrl(school.logoUrl);
        const logoHtml = logoUrl
          ? `<img src="${esc(logoUrl)}" alt="" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" style="display:block"/><div class="school-logo-initial" style="display:none">${esc((school.name || 'S')[0])}</div>`
          : `<div class="school-logo-initial">${esc((school.name || 'S')[0])}</div>`;
        return `<div class="school-strip"><div class="school-logo-box">${logoHtml}</div><div><p class="school-text-name">${esc(school.name)}</p>${school.address ? `<p class="school-text-sub">${esc(school.address)}</p>` : ''}</div>${code ? `<div class="school-strip-right"><span class="school-badge">${esc(code)}</span></div>` : ''}</div>`;
      }

      function renderEmergency() {
        return `<div class="card"><div class="card-head"><div class="card-head-icon" style="background:var(--red-dim);color:var(--red2)">${I.medical}</div><span class="card-head-title">Emergency Services</span></div><div class="emer-grid"><a href="tel:100" class="emer-btn"><div class="emer-icon-wrap ei-police">${I.police}</div><span class="emer-label">Police</span><span class="emer-num">100</span></a><a href="tel:108" class="emer-btn"><div class="emer-icon-wrap ei-ambulance">${I.ambulance}</div><span class="emer-label">Ambulance</span><span class="emer-num">108</span></a><a href="tel:101" class="emer-btn"><div class="emer-icon-wrap ei-fire">${I.fire}</div><span class="emer-label">Fire</span><span class="emer-num">101</span></a></div></div>`;
      }

      function renderChips(label, value, cls, iconKey) {
        if (!value) return '';
        const items = String(value)
          .split(',')
          .map((s) => s.trim())
          .filter(Boolean);
        if (!items.length) return '';
        return `<div class="chip-section"><span class="chip-section-label">${esc(label)}</span><div class="chip-row">${items.map((i) => `<span class="med-chip ${cls}"><span style="display:inline-flex;opacity:0.8">${I[iconKey] || ''}</span>${esc(i)}</span>`).join('')}</div></div>`;
      }

      function renderContacts(contacts, token) {
        if (!contacts?.length) return '<div class="empty-row">No emergency contacts on file</div>';
        return contacts
          .map((c) => {
            const avi = initials(c.name);
            let actions = '';
            if (c.phone)
              actions += `<a class="contact-btn cb-call" href="/s/call/${esc(c.id || '')}/${esc(token)}" title="Call">${I.phone}</a>`;
            if (c.phone)
              actions += `<a class="contact-btn cb-wa" href="/s/wa/${esc(c.id || '')}/${esc(token)}" title="WhatsApp">${I.whatsapp}</a>`;
            return `<div class="contact-item"><div class="contact-avi"><span class="contact-avi-text">${esc(avi)}</span></div><div class="contact-body"><p class="contact-name">${esc(c.name)}</p><p class="contact-rel">${esc(c.relation || 'Contact')}</p>${c.phone ? `<p class="contact-phone">${esc(c.phone)}</p>` : ''}</div>${actions ? `<div class="contact-actions">${actions}</div>` : ''}</div>`;
          })
          .join('');
      }

      function renderActiveProfile(data, token) {
        const p = data.profile || {};
        const school = data.school || {};
        const visibility = data.visibility || p.visibility || 'PUBLIC';
        const rawPhoto = p.photoUrl || null;
        const photoUrl = fixCdnUrl(rawPhoto);
        const schoolLogoFixed = school ? { ...school, logoUrl: fixCdnUrl(school.logoUrl) } : null;

        const avatarInner = photoUrl
          ? `<img src="${esc(photoUrl)}" alt="" onerror="this.style.display='none';document.getElementById('avi-init').style.display='flex'"/><div id="avi-init" class="avatar-initials" style="display:none">${esc(initials(p.name || '?'))}</div>`
          : `<div class="avatar-initials">${esc(initials(p.name || '?'))}</div>`;

        const chips = [];
        if (p.grade && p.section)
          chips.push(
            `<span class="chip"><span style="display:inline-flex;margin-right:2px;opacity:0.6">${I.class_}</span>Class ${esc(p.grade)}&ndash;${esc(p.section)}</span>`
          );
        else if (p.grade)
          chips.push(
            `<span class="chip"><span style="display:inline-flex;margin-right:2px;opacity:0.6">${I.class_}</span>Class ${esc(p.grade)}</span>`
          );
        if (p.gender) {
          const gmap = { MALE: 'Male', FEMALE: 'Female', OTHER: 'Other' };
          chips.push(
            `<span class="chip"><span style="display:inline-flex;margin-right:2px;opacity:0.6">${I.gender}</span>${esc(gmap[p.gender] || p.gender)}</span>`
          );
        }

        const bloodHtml = p.bloodGroup
          ? `<div class="blood-pill"><span style="display:inline-flex;color:var(--red2)">${I.blood}</span><span class="blood-pill-type">${esc(p.bloodGroup)}</span><span class="blood-pill-label">Blood</span></div>`
          : '';

        const allergyChips = renderChips('Allergies', p.allergies, 'mc-red', 'alert');
        const condChips = renderChips('Conditions', p.conditions, 'mc-amber', 'condition');
        const medChips = renderChips('Medications', p.medications, 'mc-blue', 'pill');
        const hasMedical =
          p.bloodGroup || p.allergies || p.conditions || p.medications || p.doctor || p.notes;

        let medHtml = '';
        if (visibility !== 'HIDDEN' && hasMedical) {
          const doctorHtml = p.doctor
            ? `<div class="hr"></div><div class="doctor-row"><div class="doctor-avi">${I.doctor}</div><div style="flex:1"><p class="contact-name">${esc(p.doctor.name || p.doctor)}</p><p class="contact-rel">Doctor / Physician</p></div>${p.doctor.phone ? `<a class="call-btn cb-green" href="/s/doctor-call/${esc(token)}">${I.phone} Call</a>` : ''}</div>`
            : '';
          const notesHtml = p.notes
            ? `<div class="hr"></div><p class="notes-text">"${esc(p.notes)}"</p>`
            : '';
          medHtml = `<div class="card"><div class="card-head"><div class="card-head-icon" style="background:var(--red-dim);color:var(--red2)">${I.medical}</div><span class="card-head-title">Medical Information</span></div>${allergyChips}${condChips}${medChips}${!allergyChips && !condChips && !medChips ? '<div class="empty-row">No medical alerts recorded</div>' : ''}${doctorHtml}${notesHtml}</div>`;
        }

        let contactsHtml = '';
        if (visibility === 'HIDDEN') {
          // no contacts shown
        } else if (visibility === 'MINIMAL') {
          if (p.primaryContact) {
            contactsHtml = `<div class="card"><div class="card-head"><div class="card-head-icon" style="background:var(--red-dim);color:var(--red2)">${I.shield}</div><span class="card-head-title">Primary Contact</span></div>${renderContacts([{ ...p.primaryContact, id: p.primaryContact.id || 'primary' }], token)}</div>`;
          }
        } else {
          const cnt = p.contacts?.length || 0;
          contactsHtml = `<div class="card"><div class="card-head"><div class="card-head-icon" style="background:var(--red-dim);color:var(--red2)">${I.shield}</div><span class="card-head-title">Emergency Contacts</span>${cnt ? `<span class="card-head-count">${cnt}</span>` : ''}</div>${renderContacts(p.contacts || [], token)}</div>`;
        }

        let visNotice = '';
        if (visibility === 'HIDDEN')
          visNotice = `<div class="notice notice-hidden"><span style="color:var(--text2);margin-top:1px">${I.lock}</span><span>Detailed medical information is restricted by this family. Contact the school for further details.</span></div>`;
        else if (visibility === 'MINIMAL')
          visNotice = `<div class="notice notice-minimal"><span style="color:var(--amber);margin-top:1px">${I.warning}</span><span>Only primary contact is visible — profile restricted by this family.</span></div>`;

        const schoolPhone = school.phone;
        const schoolContactHtml = `<div class="card"><div class="card-head"><div class="card-head-icon" style="background:rgba(255,255,255,0.04);color:var(--text2)">${I.school}</div><span class="card-head-title">School Contact</span></div><div class="school-call"><div style="width:40px;height:40px;border-radius:50%;background:var(--bg3);border:1px solid var(--line2);display:flex;align-items:center;justify-content:center;flex-shrink:0">${schoolLogoFixed?.logoUrl ? `<img src="${esc(fixCdnUrl(school.logoUrl))}" style="width:28px;height:28px;border-radius:50%;object-fit:cover" onerror="this.style.display='none'">` : ''}<span style="font-family:'Syne',sans-serif;font-size:0.75rem;font-weight:700;color:var(--text2)">${esc((school.name || 'S')[0])}</span></div><div class="school-call-info"><p class="school-call-name">${esc(school.name || 'School')}</p><p class="school-call-sub">${schoolPhone ? `+91 ${esc(schoolPhone)}` : 'School helpline'}</p></div>${schoolPhone ? `<a class="call-btn cb-blue" href="/s/school-call/${esc(token)}">${I.phone} Call</a>` : '<span style="font-size:0.72rem;color:var(--text3)">No number</span>'}</div></div>`;

        const scanStrip = `<div class="scan-strip"><span class="scan-strip-left">Scanned at ${nowStr()}</span><span class="scan-strip-right">RESQID</span></div>`;

        return `<div style="background:var(--bg1)"><div class="critical-strip"><div class="critical-dot"></div><span class="critical-strip-text">Emergency Identity Card</span><div class="critical-strip-spacer"></div><span class="critical-time">${nowStr()}</span></div><div class="hero"><div class="hero-glow"></div><div class="hero-glow2"></div><div class="hero-inner"><div class="avatar-shell"><div class="avatar-ring"><div class="avatar-img">${avatarInner}</div></div><div class="online-dot"></div></div><div class="hero-info"><p class="hero-label">Student Profile</p><p class="hero-name">${esc(p.name || 'Student')}</p><div class="hero-chips">${chips.join('')}</div>${bloodHtml}</div></div>${renderSchoolStrip(schoolLogoFixed, school.code)}</div>${scanStrip}</div><div class="content">${visNotice}${renderEmergency()}${medHtml}${contactsHtml}${schoolContactHtml}</div>${footer()}`;
      }

      // ── Main ────────────────────────────────────────────────
      async function main() {
        const token = getToken();
        const app = document.getElementById('app');
        const loader = document.getElementById('loading');
        const hide = () => {
          loader.style.opacity = '0';
          setTimeout(() => (loader.style.display = 'none'), 500);
        };

        if (!token) {
          hide();
          app.innerHTML = renderStatus({
            iconKey: 'cross',
            iconClass: 'si-error',
            title: 'Invalid QR Code',
            message: 'This QR code could not be verified. Please contact the school.',
          });
          app.classList.add('visible');
          return;
        }

        const location = await resolveLocation();
        let data;
        try {
          const res = await fetch(buildUrl(`/s/${encodeURIComponent(token)}`, location), {
            method: 'GET',
            headers: { Accept: 'application/json' },
            cache: 'no-store',
          });
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          data = await res.json();
        } catch {
          hide();
          app.innerHTML = renderStatus({
            iconKey: 'warn_big',
            iconClass: 'si-warn',
            title: 'Connection Error',
            message: 'Could not reach the server. Check your connection and try again.',
          });
          app.classList.add('visible');
          return;
        }
        hide();

        switch (data.state) {
          case 'ACTIVE':
            app.innerHTML = renderActiveProfile(data, token);
            break;
          case 'INACTIVE':
          case 'EXPIRED':
          case 'REVOKED':
            app.innerHTML = renderStatus({
              iconKey: 'cross',
              iconClass: 'si-error',
              title: 'Card Inactive',
              message: data.message || 'This card is no longer active.',
              school: data.school,
            });
            break;
          case 'UNREGISTERED':
            app.innerHTML = renderStatus({
              iconKey: 'info',
              iconClass: 'si-info',
              title: 'Not Registered',
              message: data.message || 'This card has not been registered yet.',
              school: data.school,
            });
            break;
          case 'ISSUED':
            app.innerHTML = renderStatus({
              iconKey: 'pending',
              iconClass: 'si-info',
              title: 'Pending Activation',
              message: data.message || 'This card has been issued but is not yet activated.',
              school: data.school,
            });
            break;
          default:
            app.innerHTML = renderStatus({
              iconKey: 'cross',
              iconClass: 'si-error',
              title: 'Invalid QR Code',
              message: data.message || 'This QR code could not be verified.',
            });
        }
        app.classList.add('visible');
      }
      main();
    </script>
  </body>
</html>
