        cross:
          '<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#ff3d3d" stroke-width="1.6"/><path d="M15 9l-6 6M9 9l6 6" stroke="#ff3d3d" stroke-width="1.8" stroke-linecap="round"/></svg>',
