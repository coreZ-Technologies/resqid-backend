import { prisma } from '#config/prisma.js';

// ─── List ─────────────────────────────────────────────────────────────────────

export const findBySchool = async (schoolId, query = {}) => {
  const {
    page = 1,
    limit = 20,
    type,
    severity,
    status,
    studentId,
    startDate,
    endDate,
    sortBy = 'timestamp',
    sortOrder = 'desc',
  } = query;

  const where = { schoolId };

  if (type) where.type = type;
  if (severity) where.severity = severity;
  if (studentId) where.studentId = studentId;
  if (status === 'OPEN') where.resolvedAt = null;
  if (status === 'RESOLVED') where.resolvedAt = { not: null };
  if (startDate || endDate) {
    where.timestamp = {};
    if (startDate) where.timestamp.gte = new Date(startDate);
    if (endDate) where.timestamp.lte = new Date(endDate);
  }

  const [anomalies, total] = await Promise.all([
    prisma.scanAnomaly.findMany({
      where,
      skip: (page - 1) * limit,
      take: limit,
      orderBy: { [sortBy]: sortOrder },
      include: {
        student: {
          select: {
            id: true,
            firstName: true,
            lastName: true,
            grade: true,
            section: true,
            photoUrl: true,
          },
        },
      },
    }),
    prisma.scanAnomaly.count({ where }),
  ]);

  return { anomalies, total };
};

// ─── Find All (Super Admin) ───────────────────────────────────────────────────

export const findAll = async (query = {}) => {
  const {
    page = 1,
    limit = 20,
    type,
    severity,
    status,
    schoolId,
    startDate,
    endDate,
    sortBy = 'timestamp',
    sortOrder = 'desc',
  } = query;

  const where = {};
  if (type) where.type = type;
  if (severity) where.severity = severity;
  if (schoolId) where.schoolId = schoolId;
  if (status === 'OPEN') where.resolvedAt = null;
  if (status === 'RESOLVED') where.resolvedAt = { not: null };
  if (startDate || endDate) {
    where.timestamp = {};
    if (startDate) where.timestamp.gte = new Date(startDate);
    if (endDate) where.timestamp.lte = new Date(endDate);
  }

  const [anomalies, total] = await Promise.all([
    prisma.scanAnomaly.findMany({
      where,
      skip: (page - 1) * limit,
      take: limit,
      orderBy: { [sortBy]: sortOrder },
      include: {
        student: {
          select: {
            id: true,
            firstName: true,
            lastName: true,
            grade: true,
            section: true,
            photoUrl: true,
          },
        },
        school: { select: { id: true, name: true } },
      },
    }),
    prisma.scanAnomaly.count({ where }),
  ]);

  return { anomalies, total };
};

// ─── Get One ──────────────────────────────────────────────────────────────────

export const findById = (id, schoolId = null) => {
  const where = { id };
  if (schoolId) where.schoolId = schoolId;

  return prisma.scanAnomaly.findFirst({
    where,
    include: {
      student: {
        select: {
          id: true,
          firstName: true,
          lastName: true,
          grade: true,
          section: true,
          photoUrl: true,
        },
      },
      school: { select: { id: true, name: true } },
      scan: { select: { id: true, scannedAt: true, ipAddress: true, device: true } },
    },
  });
};

// ─── Resolve ──────────────────────────────────────────────────────────────────

export const resolve = (id, resolution) =>
  prisma.scanAnomaly.update({
    where: { id },
    data: {
      resolvedAt: new Date(),
      resolution: resolution || 'Manually resolved',
      status: 'RESOLVED',
    },
  });

// ─── Stats ─────────────────────────────────────────────────────────────────────

export const getStats = async (schoolId) => {
  const where = { schoolId };

  const [total, open, byType, bySeverity, thisWeek] = await Promise.all([
    prisma.scanAnomaly.count({ where }),
    prisma.scanAnomaly.count({ where: { ...where, resolvedAt: null } }),
    prisma.scanAnomaly.groupBy({ by: ['type'], where, _count: true }),
    prisma.scanAnomaly.groupBy({ by: ['severity'], where, _count: true }),
    prisma.scanAnomaly.count({
      where: { ...where, timestamp: { gte: new Date(Date.now() - 7 * 24 * 60 * 60 * 1000) } },
    }),
  ]);

  return {
    total,
    open,
    resolved: total - open,
    thisWeek,
    byType: byType.map((t) => ({ type: t.type, count: t._count })),
    bySeverity: bySeverity.map((s) => ({ severity: s.severity, count: s._count })),
  };
};
