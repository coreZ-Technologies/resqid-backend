import { ApiError } from '#shared/response/ApiError.js';
import * as repo from './anomaly.repository.js';

export const list = async (req) => {
  const { role, schoolId } = req.user;
  const query = req.query;

  if (role === 'SUPER_ADMIN') {
    return repo.findAll(query);
  }

  if (!schoolId) throw ApiError.tenantRequired();
  return repo.findBySchool(schoolId, query);
};

export const getOne = async (id, req) => {
  const { role, schoolId } = req.user;
  const anomaly = await repo.findById(id, role === 'SUPER_ADMIN' ? null : schoolId);
  if (!anomaly) throw ApiError.notFound('Anomaly not found');
  return anomaly;
};

export const resolve = async (id, data, req) => {
  const { role, schoolId } = req.user;
  const anomaly = await repo.findById(id, role === 'SUPER_ADMIN' ? null : schoolId);
  if (!anomaly) throw ApiError.notFound('Anomaly not found');
  if (anomaly.resolvedAt) throw ApiError.badRequest('Anomaly already resolved');
  return repo.resolve(id, data.resolution);
};

export const getStats = async (schoolId) => {
  return repo.getStats(schoolId);
};
