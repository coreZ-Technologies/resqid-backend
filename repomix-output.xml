  grade        String? // "10" (null for staff sessions)
  section      String? // "A" (null for staff sessions)
  subject      String? // Subject name (for class-specific attendance)
  classGroupId String? // Link to timetable class
  classGroup   ClassGroup? @relation(fields: [classGroupId], references: [id])

  // For Staff Sessions
  isStaffSession Boolean @default(false)

  // Session Timing
  scheduledStart DateTime // Planned start time
  scheduledEnd   DateTime? // Planned end time
  startedAt      DateTime? // Actual start time
  endedAt        DateTime? // Actual end time
  lateThreshold  Int       @default(15) // Minutes after which marked LATE

  // Created by SchoolUser (teacher/admin)
  createdById String
  createdBy   SchoolUser @relation("SessionCreator", fields: [createdById], references: [id])

  // Status
  isActive   Boolean @default(true)
  isArchived Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  studentRecords StudentAttendanceRecord[]
  staffRecords   StaffAttendanceRecord[]
  taps           AttendanceTap[]
  reports        AttendanceReport[]

  @@index([schoolId, type])
  @@index([schoolId, isActive])
  @@index([grade, section])
  @@index([isStaffSession])
  @@index([classGroupId])
  @@map("attendance_sessions")
}

// ─── Raw Tap from Device (RFID/Biometric/QR) ──────────────────────────────────

model AttendanceTap {
  id        String            @id @default(cuid())
  sessionId String
  session   AttendanceSession @relation(fields: [sessionId], references: [id])
  schoolId  String
  school    School            @relation(fields: [schoolId], references: [id])

  // Who tapped (student OR staff, not both)
  studentId String?
  student   Student?    @relation(fields: [studentId], references: [id])
  staffId   String?
  staff     SchoolUser? @relation("StaffTap", fields: [staffId], references: [id])

  // Tap Data
  uidHash    String // Hashed card/fingerprint ID
  tapType    String // "RFID_CARD", "FINGERPRINT", "QR_CODE", "FACE"
  deviceId   String? // Reference to AttendanceDevice
  deviceName String? // "Main Gate Reader", "Class 10A Reader"

  // Location Data (for GPS-based attendance)
  latitude  Float?
  longitude Float?
  location  String? // "Main Building, Gate 1"

  // Processing
  tappedAt    DateTime  @default(now())
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String? // "Invalid card", "Duplicate tap", "Unknown user"

  // Duplicate prevention
  isDuplicate   Boolean @default(false)
  duplicateOfId String? // Reference to first tap if duplicate

  // Metadata
  metadata                 Json?
  studentAttendanceRecords StudentAttendanceRecord[]
  staffAttendanceRecords   StaffAttendanceRecord[]

  @@index([sessionId])
  @@index([studentId])
  @@index([staffId])
  @@index([processed])
  @@index([tappedAt])
  @@index([uidHash])
  @@map("attendance_taps")
}

// ─── Student Attendance Record ────────────────────────────────────────────────

model StudentAttendanceRecord {
  id        String            @id @default(cuid())
  sessionId String
  session   AttendanceSession @relation(fields: [sessionId], references: [id])
  studentId String
  student   Student           @relation(fields: [studentId], references: [id])
  schoolId  String
  school    School            @relation(fields: [schoolId], references: [id])

  // Attendance Details
  status AttendanceStatus @default(PRESENT)
  mode   AttendanceMode   @default(RFID)

  // Timing
  scheduledTime DateTime? // When student was expected
  markedAt      DateTime  @default(now())
  lateBy        Int? // Minutes late (if LATE status)

  // Who marked it
  markedBy     String? // SchoolUser ID (null if auto/RFID)
  markedByUser SchoolUser?    @relation("StudentMarkedBy", fields: [markedBy], references: [id])
  tapId        String? // Reference to the tap
  tap          AttendanceTap? @relation(fields: [tapId], references: [id])

  // Additional Info
  reason         String? // Reason for absence/late
  remark         String? // Teacher's remark
  isVerified     Boolean     @default(false)
  verifiedBy     String? // SchoolUser who verified
  verifiedByUser SchoolUser? @relation("StudentVerifiedBy", fields: [verifiedBy], references: [id])

  // Parent Notification
  parentNotified     Boolean   @default(false)
  parentNotifiedAt   DateTime?
  parentAcknowledged Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, studentId])
  @@index([schoolId, sessionId])
  @@index([studentId, createdAt])
  @@index([status])
  @@index([markedAt])
  @@index([parentNotified])
  @@map("student_attendance_records")
}

// ─── Staff Attendance Record ──────────────────────────────────────────────────

model StaffAttendanceRecord {
  id        String            @id @default(cuid())
  sessionId String
  session   AttendanceSession @relation(fields: [sessionId], references: [id])
  staffId   String
  staff     SchoolUser        @relation("StaffRecord", fields: [staffId], references: [id])
  schoolId  String
  school    School            @relation(fields: [schoolId], references: [id])

  // Attendance Details
  status AttendanceStatus @default(PRESENT)
  mode   AttendanceMode   @default(RFID)

  // Timing
  scheduledTime DateTime? // Expected check-in time
  checkInAt     DateTime? // Actual check-in time
  checkOutAt    DateTime? // Check-out time
  lateBy        Int? // Minutes late

  // Work Hours
  totalHours    Float? // Total hours present
  overtimeHours Float? // Overtime hours

  // Who marked it
  markedBy     String? // SchoolUser ID (null if self/RFID)
  markedByUser SchoolUser?    @relation("StaffMarkedBy", fields: [markedBy], references: [id])
  tapId        String? // Reference to the tap
  tap          AttendanceTap? @relation(fields: [tapId], references: [id])

  // Additional Info
  reason         String? // Reason for absence/late
  remark         String? // Admin remark
  isApproved     Boolean     @default(false)
  approvedBy     String? // SchoolUser who approved
  approvedByUser SchoolUser? @relation("StaffApprovedBy", fields: [approvedBy], references: [id])

  // Leave Integration
  leaveType    String? // "SICK", "CASUAL", "EMERGENCY"
  leaveApplied Boolean @default(false)
  leaveId      String? // Reference to leave record

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, staffId])
  @@index([schoolId, sessionId])
  @@index([staffId, createdAt])
  @@index([status])
  @@index([checkInAt])
  @@map("staff_attendance_records")
}

// ─── Attendance Report ────────────────────────────────────────────────────────

model AttendanceReport {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Report Details
  title String // "Monthly Attendance - Class 10 - January 2024"
  type  ReportType

  // Filters Applied
  filters Json? // { grade: "10", section: "A", month: "2024-01" }

  // Report Data
  summary Json // { total: 50, present: 45, absent: 3, late: 2 }
  details Json? // Full report data

  // Generated By (SchoolUser)
  generatedById String
  generatedBy   SchoolUser @relation("ReportGeneratedBy", fields: [generatedById], references: [id])

  // Session Reference (optional)
  sessionId String?
  session   AttendanceSession? @relation(fields: [sessionId], references: [id])

  // Export Info
  format  ReportFormat @default(JSON)
  fileUrl String? // If exported to file

  // Date Range
  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())

  @@index([schoolId, type])
  @@index([startDate, endDate])
  @@index([generatedById])
  @@map("attendance_reports")
}

// ─── Attendance Settings ──────────────────────────────────────────────────────

model AttendanceSettings {
  id       String @id @default(cuid())
  schoolId String @unique
  school   School @relation(fields: [schoolId], references: [id])

  // Student Settings
  studentCheckInStart  String @default("07:00")
  studentCheckInEnd    String @default("09:00")
  studentLateThreshold Int    @default(15)
  studentHalfDayAfter  Int    @default(120)

  // Staff Settings
  staffCheckInStart  String @default("07:00")
  staffCheckInEnd    String @default("10:00")
  staffLateThreshold Int    @default(15)
  staffWorkingHours  Float  @default(8.0)

  // Auto-mark settings
  autoMarkAbsent Boolean @default(true)
  autoMarkAfter  Int     @default(60)

  // Notification Settings
  notifyParentsOnAbsent     Boolean @default(true)
  notifyParentsOnLate       Boolean @default(true)
  notifyAdminsOnStaffAbsent Boolean @default(true)

  // GPS Settings
  gpsEnabled Boolean @default(false)
  gpsRadius  Int? // in meters

  // Updated by (SchoolUser)
  updatedById String?
  updatedBy   SchoolUser? @relation("SettingsUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendance_settings")
}

// ─── Attendance Summary (Pre-computed) ────────────────────────────────────────

model AttendanceSummary {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Entity (student or staff)
  entityType String // "STUDENT" or "STAFF"
  entityId   String // studentId or staffId (SchoolUser ID)

  // Period
  period      SummaryPeriod
  periodStart DateTime
  periodEnd   DateTime

  // Stats
  totalSessions     Int
  presentCount      Int
  absentCount       Int
  lateCount         Int
  excusedCount      Int
  halfDayCount      Int
  attendancePercent Float

  // For staff
  totalHours    Float?
  overtimeHours Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityType, entityId, period, periodStart])
  @@index([schoolId, entityType])
  @@index([entityId, period])
  @@map("attendance_summaries")
}
