import { z } from 'zod';

const cuid = z.string().min(1, 'Invalid ID format');

// ─── Create Teacher ───────────────────────────────────────────────────────────

export const createTeacherSchema = z.object({
  firstName: z.string().min(1).max(100),
  lastName: z.string().min(1).max(100),
  email: z.string().email().max(254),
  phone: z.string().min(10).max(20),
  employeeId: z.string().max(50).optional(),
  joiningDate: z.string().datetime().optional(),
  dateOfBirth: z.string().datetime().optional(),
  gender: z.enum(['MALE', 'FEMALE', 'OTHER']).optional(),
  bloodGroup: z
    .enum([
      'A_POSITIVE',
      'A_NEGATIVE',
      'B_POSITIVE',
      'B_NEGATIVE',
      'AB_POSITIVE',
      'AB_NEGATIVE',
      'O_POSITIVE',
      'O_NEGATIVE',
      'UNKNOWN',
    ])
    .optional(),
  address: z.string().max(500).optional(),
  photoUrl: z.string().url().optional(),

  // Teaching
  subjects: z.array(z.string()).min(1).max(20),
  qualifications: z.array(z.string()).max(10).optional().default([]),
  experience: z.number().int().min(0).max(50).optional().default(0),

  // Workload
  maxPeriodsPerDay: z.number().int().min(1).max(12).optional().default(6),
  maxPeriodsPerWeek: z.number().int().min(1).max(60).optional().default(30),
  maxConsecutivePeriods: z.number().int().min(1).max(8).optional().default(3),
  isPartTime: z.boolean().optional().default(false),

  // Status
  isActive: z.boolean().optional().default(true),

  // Login
  password: z.string().min(8).max(128),

  // Wellness (optional at creation)
  wellness: z
    .object({
      isPregnant: z.boolean().optional(),
      needsGroundFloor: z.boolean().optional(),
      needsAccessibleRoom: z.boolean().optional(),
      isSenior: z.boolean().optional(),
      avoidEarlyMorning: z.boolean().optional(),
      needsCommuteBuffer: z.boolean().optional(),
      burnoutRisk: z.boolean().optional(),
    })
    .optional()
    .default({}),

  // Class assignments
  classIds: z.array(z.string()).optional().default([]),
});

// ─── Update Teacher ───────────────────────────────────────────────────────────

export const updateTeacherSchema = createTeacherSchema.partial().omit({ password: true });

// ─── Update Wellness ──────────────────────────────────────────────────────────

export const updateWellnessSchema = z.object({
  isPregnant: z.boolean().optional(),
  dueDate: z.string().datetime().optional().nullable(),
  needsGroundFloor: z.boolean().optional(),
  needsAccessibleRoom: z.boolean().optional(),
  mobilityAid: z.string().max(100).optional().nullable(),
  medicalConditions: z.array(z.string()).optional(),
  isSenior: z.boolean().optional(),
  preferredMaxPerDay: z.number().int().min(1).max(12).optional().nullable(),
  preferredMaxPerWeek: z.number().int().min(1).max(60).optional().nullable(),
  avoidEarlyMorning: z.boolean().optional(),
  avoidLateEvening: z.boolean().optional(),
  needsCommuteBuffer: z.boolean().optional(),
  commuteDistance: z.number().int().optional().nullable(),
  commuteTime: z.number().int().optional().nullable(),
  preferredSlots: z
    .array(
      z.object({
        day: z.number().int().min(1).max(7),
        period: z.number().int().min(1).max(12),
      })
    )
    .optional()
    .nullable(),
  personalBlocks: z
    .array(
      z.object({
        day: z.number().int().min(1).max(7),
        period: z.number().int().min(1).max(12),
        reason: z.string().max(200).optional(),
      })
    )
    .optional()
    .nullable(),
  burnoutRisk: z.boolean().optional(),
  burnoutScore: z.number().int().min(0).max(100).optional(),
  wellnessNotes: z.string().max(1000).optional().nullable(),
  emergencyContact: z.string().max(200).optional().nullable(),
  emergencyPhone: z.string().max(20).optional().nullable(),
});

// ─── Bulk Create ──────────────────────────────────────────────────────────────

export const bulkCreateTeacherSchema = z.object({
  teachers: z
    .array(
      z.object({
        firstName: z.string().min(1).max(100),
        lastName: z.string().min(1).max(100),
        email: z.string().email().max(254),
        phone: z.string().min(10).max(20),
        subjects: z.string(), // Comma-separated in CSV
        qualifications: z.string().optional(), // Comma-separated
        maxPeriodsPerDay: z.coerce.number().int().min(1).max(12).optional().default(6),
        maxPeriodsPerWeek: z.coerce.number().int().min(1).max(60).optional().default(30),
        isPartTime: z.coerce.boolean().optional().default(false),
        password: z.string().min(8).max(128).optional().default('Teacher@123'),
      })
    )
    .min(1)
    .max(500),
});

// ─── List Query ───────────────────────────────────────────────────────────────

export const teacherListQuerySchema = z.object({
  page: z.coerce.number().int().min(1).default(1),
  limit: z.coerce.number().int().min(1).max(100).default(20),
  search: z.string().optional(),
  subject: z.string().optional(),
  status: z.enum(['active', 'on_leave', 'inactive']).optional(),
  isPartTime: z.coerce.boolean().optional(),
  grade: z.string().optional(), // For parent: find class teacher
  section: z.string().optional(), // For parent: find class teacher
  schoolId: z.string().optional(), // For super admin: filter by school
  sortBy: z.enum(['name', 'subject', 'experience', 'createdAt']).default('name'),
  sortOrder: z.enum(['asc', 'desc']).default('asc'),
});

// ─── Teacher Self-Update (Restricted fields) ─────────────────────────────────

export const updateOwnProfileSchema = z.object({
  firstName: z.string().min(1).max(100).optional(),
  lastName: z.string().min(1).max(100).optional(),
  phone: z.string().min(10).max(20).optional(),
  email: z.string().email().max(254).optional(),
  address: z.string().max(500).optional().nullable(),
  city: z.string().max(100).optional().nullable(),
  state: z.string().max(100).optional().nullable(),
  pincode: z.string().max(10).optional().nullable(),
  photoUrl: z.string().url().optional().nullable(),
  preferredDays: z.array(z.number().int().min(1).max(7)).optional(),
  preferredPeriods: z.array(z.number().int().min(1).max(12)).optional(),
  preferredRooms: z.array(z.string()).optional(),
});

// ─── Change Password ─────────────────────────────────────────────────────────

export const changePasswordSchema = z.object({
  currentPassword: z.string().min(1, 'Current password is required'),
  newPassword: z.string().min(8).max(128),
});

// ─── Params ───────────────────────────────────────────────────────────────────

export const teacherIdParamsSchema = z.object({ id: cuid });
