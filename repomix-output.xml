// =============================================================================
// modules/teachers/teacher.service.js — RESQID
// =============================================================================

import { ApiError } from '#shared/response/ApiError.js';
import * as repo from './teacher.repository.js';
import { prisma } from '#config/prisma.js';

export const list = async (req) => {
  const { role, schoolId } = req.user;
  const query = req.query;

  // Super Admin — view by school filter
  if (role === 'SUPER_ADMIN') {
    return repo.findAll(query);
  }

  // Parent — find class teacher
  if (role === 'PARENT') {
    if (query.grade && query.section) {
      const teacher = await repo.findClassTeacher(
        schoolId || query.schoolId,
        query.grade,
        query.section
      );
      return { teachers: teacher ? [teacher] : [], total: teacher ? 1 : 0 };
    }
    return { teachers: [], total: 0 };
  }

  // School Admin — their school
  if (!schoolId) throw ApiError.tenantRequired();
  return repo.findBySchool(schoolId, query);
};

export const getOne = async (id, req) => {
  const { role, schoolId, id: userId } = req.user;

  // Teacher can only view own profile
  if (role === 'TEACHER') {
    const teacher = await prisma.teacher.findFirst({
      where: { userId, deletedAt: null },
      select: { id: true },
    });
    if (!teacher || teacher.id !== id) throw ApiError.forbidden('Can only view own profile');
  }

  const teacher = await repo.findById(id, role === 'SUPER_ADMIN' ? null : schoolId);
  if (!teacher) throw ApiError.notFound('Teacher not found');
  return teacher;
};

export const create = async (data, schoolId) => {
  const existing = await prisma.teacher.findFirst({
    where: { email: data.email, schoolId, deletedAt: null },
  });
  if (existing) throw ApiError.conflict('Teacher with this email already exists');
  return repo.create(schoolId, data);
};

export const update = async (id, data, schoolId) => {
  const teacher = await repo.findById(id, schoolId);
  if (!teacher) throw ApiError.notFound('Teacher not found');
  return repo.update(id, data);
};

export const remove = async (id, schoolId) => {
  const teacher = await repo.findById(id, schoolId);
  if (!teacher) throw ApiError.notFound('Teacher not found');
  return repo.remove(id);
};

export const bulkCreate = async (teachers, schoolId) => {
  const result = await repo.bulkCreate(schoolId, teachers);
  return { count: result.count };
};

export const updateWellness = async (teacherId, data, schoolId) => {
  const teacher = await prisma.teacher.findFirst({
    where: { id: teacherId, schoolId, deletedAt: null },
  });
  if (!teacher) throw ApiError.notFound('Teacher not found');
  return repo.updateWellness(teacherId, data);
};

export const getStats = async (schoolId) => repo.getStats(schoolId);

export const getDropdown = async (schoolId) => repo.findForDropdown(schoolId);

// ─── Teacher Self-Update ──────────────────────────────────────────────────────

export const updateOwnProfile = async (userId, data) => {
  const teacher = await prisma.teacher.findFirst({
    where: { userId, deletedAt: null },
    select: { id: true },
  });
  if (!teacher) throw ApiError.notFound('Teacher profile not found');

  // Only allow safe fields
  const allowed = [
    'firstName',
    'lastName',
    'phone',
    'email',
    'address',
    'city',
    'state',
    'pincode',
    'photoUrl',
    'preferredDays',
    'preferredPeriods',
    'preferredRooms',
  ];
  const safeData = {};
  for (const key of allowed) {
    if (data[key] !== undefined) safeData[key] = data[key];
  }

  if (safeData.firstName || safeData.lastName) {
    const current = await prisma.teacher.findUnique({
      where: { id: teacher.id },
      select: { name: true },
    });
    const firstName = safeData.firstName || current.name?.split(' ')[0] || '';
    const lastName = safeData.lastName || current.name?.split(' ').slice(1).join(' ') || '';
    safeData.name = `${firstName} ${lastName}`.trim();
  }

  return repo.update(teacher.id, safeData);
};

// ─── Change Own Password ─────────────────────────────────────────────────────

export const changeOwnPassword = async (userId, currentPassword, newPassword) => {
  const schoolUser = await prisma.schoolUser.findUnique({
    where: { id: userId },
    select: { id: true, passwordHash: true },
  });
  if (!schoolUser) throw ApiError.notFound('User not found');

  const isValid = await verifyPassword(currentPassword, schoolUser.passwordHash);
  if (!isValid) throw ApiError.badRequest('Current password is incorrect');

  const newHash = await hashPassword(newPassword);
  await prisma.schoolUser.update({
    where: { id: userId },
    data: { passwordHash: newHash, isPasswordDefault: false, passwordChangedAt: new Date() },
  });

  return { message: 'Password changed successfully' };
};
</file>

