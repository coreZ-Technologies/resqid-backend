      },
      schoolUser: {
        select: { id: true, email: true, role: true, isActive: true, lastLoginAt: true },
      },
      timetableAssignments: {
        take: 10,
        orderBy: { createdAt: 'desc' },
        select: {
          id: true,
          dayOfWeek: true,
          periodNumber: true,
          periodType: true,
          subject: { select: { id: true, name: true } },
          classGroup: { select: { id: true, grade: true, section: true } },
          room: { select: { id: true, roomNumber: true } },
        },
      },
    },
  });
};

// ─── Create ───────────────────────────────────────────────────────────────────

export const create = async (schoolId, data) => {
  const { wellness, classIds, password, ...teacherData } = data;
  const passwordHash = password ? await hashPassword(password) : null;

  return prisma.teacher.create({
    data: {
      ...teacherData,
      schoolId,
      name: `${teacherData.firstName} ${teacherData.lastName}`.trim(),
      wellness:
        wellness && Object.keys(wellness).length > 0
          ? { create: { schoolId, ...wellness } }
          : undefined,
      classGroups: classIds?.length ? { connect: classIds.map((id) => ({ id })) } : undefined,
      schoolUser: passwordHash
        ? {
            create: {
              schoolId,
              name: `${teacherData.firstName} ${teacherData.lastName}`.trim(),
              email: teacherData.email,
              phone: teacherData.phone,
              passwordHash,
              role: 'TEACHER',
            },
          }
        : undefined,
    },
    include: { wellness: true, classGroups: { select: { id: true, grade: true, section: true } } },
  });
};

// ─── Update ───────────────────────────────────────────────────────────────────

export const update = (id, data) => {
  const { wellness, classIds, ...teacherData } = data;
  return prisma.teacher.update({
    where: { id },
    data: {
      ...teacherData,
      name:
        teacherData.firstName || teacherData.lastName
          ? `${teacherData.firstName || ''} ${teacherData.lastName || ''}`.trim()
          : undefined,
      classGroups: classIds ? { set: [], connect: classIds.map((id) => ({ id })) } : undefined,
    },
  });
};

// ─── Soft Delete ──────────────────────────────────────────────────────────────

export const remove = (id) =>
  prisma.teacher.update({ where: { id }, data: { isActive: false, deletedAt: new Date() } });

// ─── Bulk Create ──────────────────────────────────────────────────────────────

export const bulkCreate = async (schoolId, teachers) => {
  const passwordHash = await hashPassword('Teacher@123');

  const data = teachers.map((t) => ({
    ...t,
    schoolId,
    name: `${t.firstName} ${t.lastName}`.trim(),
    subjects:
      t.subjects
        ?.split(',')
        .map((s) => s.trim())
        .filter(Boolean) || [],
    qualifications:
      t.qualifications
        ?.split(',')
        .map((q) => q.trim())
        .filter(Boolean) || [],
  }));

  return prisma.teacher.createMany({ data, skipDuplicates: true });
};

// ─── Update Wellness ──────────────────────────────────────────────────────────

export const updateWellness = (teacherId, data) =>
  prisma.teacherWellness.upsert({
    where: { teacherId },
    create: { teacherId, ...data },
    update: data,
  });

// ─── Stats ─────────────────────────────────────────────────────────────────────

export const getStats = async (schoolId) => {
  const [total, active, onLeave, partTime] = await Promise.all([
    prisma.teacher.count({ where: { schoolId, deletedAt: null } }),
    prisma.teacher.count({ where: { schoolId, isActive: true, deletedAt: null } }),
    prisma.teacher.count({ where: { schoolId, isOnLeave: true, deletedAt: null } }),
    prisma.teacher.count({ where: { schoolId, isPartTime: true, deletedAt: null } }),
  ]);
  return { totalTeachers: total, activeTeachers: active, onLeave, partTime };
};

// ─── Dropdown ─────────────────────────────────────────────────────────────────

export const findForDropdown = (schoolId) =>
  prisma.teacher.findMany({
    where: { schoolId, isActive: true, deletedAt: null },
    select: { id: true, name: true, subjects: true },
    orderBy: { name: 'asc' },
  });
