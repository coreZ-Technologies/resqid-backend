<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"
    />
    <meta name="theme-color" content="#050608" />
    <meta name="robots" content="noindex,nofollow" />
    <title>RESQID — Emergency Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --bg: #050608;
        --bg1: #090c12;
        --bg2: #0d1018;
        --bg3: #111520;
        --bg4: #161b28;
        --line: rgba(255, 255, 255, 0.055);
        --line2: rgba(255, 255, 255, 0.1);
        --line3: rgba(255, 255, 255, 0.16);
        --text: #f0f4ff;
        --text2: #8b95aa;
        --text3: #4e5668;
        --red: #ff3d3d;
        --red2: #ff6b6b;
        --red-dim: rgba(255, 61, 61, 0.12);
        --red-border: rgba(255, 61, 61, 0.22);
        --green: #00d68f;
        --green-dim: rgba(0, 214, 143, 0.1);
        --green-border: rgba(0, 214, 143, 0.22);
        --blue: #4d8eff;
        --blue-dim: rgba(77, 142, 255, 0.1);
        --blue-border: rgba(77, 142, 255, 0.22);
        --amber: #ffb020;
        --amber-dim: rgba(255, 176, 32, 0.1);
        --amber-border: rgba(255, 176, 32, 0.22);
        --purple: #a78bfa;
        --purple-dim: rgba(167, 139, 250, 0.1);
        --r: 16px;
        --r-sm: 10px;
        --r-lg: 22px;
        --r-xl: 28px;
      }
      html {
        background: var(--bg);
        scroll-behavior: smooth;
      }
      body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-user-select: none;
        user-select: none;
        min-height: 100vh;
        overflow-x: hidden;
      }
      #loading {
        position: fixed;
        inset: 0;
        background: var(--bg);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 24px;
        z-index: 100;
        transition: opacity 0.5s ease;
      }
      .load-logo {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .load-logo-mark {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--red-dim);
        border: 1px solid var(--red-border);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }
      .load-logo-mark::after {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 15px;
        border: 1px solid var(--red-border);
        animation: pulse-ring 1.8s ease-out infinite;
      }
      @keyframes pulse-ring {
        0% {
          opacity: 1;
          transform: scale(1);
        }
        100% {
          opacity: 0;
          transform: scale(1.5);
        }
      }
      .load-logo-name {
        font-family: 'Syne', sans-serif;
        font-size: 1.1rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text);
      }
      .load-bar {
        width: 120px;
        height: 1px;
        background: var(--line2);
        border-radius: 1px;
        overflow: hidden;
      }
      .load-bar-fill {
        height: 100%;
        width: 0;
        background: var(--red);
        border-radius: 1px;
        animation: load-prog 1.8s ease forwards;
      }
      @keyframes load-prog {
        to {
          width: 100%;
        }
      }
      .load-label {
        font-family: 'DM Mono', monospace;
        font-size: 0.62rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text3);
      }
      #app {
        display: none;
        min-height: 100vh;
      }
      #app.visible {
        display: block;
        animation: rise 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      @keyframes rise {
        from {
          opacity: 0;
          transform: translateY(24px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .status-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
        text-align: center;
        gap: 16px;
      }
      .status-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 4px;
      }
      .si-error {
        background: var(--red-dim);
        border: 1px solid var(--red-border);
      }
      .si-warn {
        background: var(--amber-dim);
        border: 1px solid var(--amber-border);
      }
      .si-info {
        background: var(--blue-dim);
        border: 1px solid var(--blue-border);
      }
      .status-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--text);
      }
      .status-msg {
        font-size: 0.875rem;
        color: var(--text2);
        max-width: 260px;
        line-height: 1.7;
        font-weight: 300;
      }
      .status-school {
        font-family: 'DM Mono', monospace;
        font-size: 0.68rem;
        color: var(--text3);
        letter-spacing: 0.08em;
        margin-top: 4px;
      }
      .loc-banner {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 300;
        background: var(--bg2);
        border-bottom: 1px solid var(--line2);
        padding: 16px;
        display: flex;
        gap: 14px;
        align-items: flex-start;
        animation: slide-down 0.3s ease;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
      }
      @keyframes slide-down {
        from {
          transform: translateY(-100%);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }
      .loc-banner-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: var(--blue-dim);
        border: 1px solid var(--blue-border);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 2px;
      }
      .loc-banner-body {
        flex: 1;
      }
      .loc-banner-title {
        font-family: 'Syne', sans-serif;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 4px;
      }
      .loc-banner-desc {
        font-size: 0.75rem;
        color: var(--text2);
        line-height: 1.6;
        margin-bottom: 14px;
        font-weight: 300;
      }
      .loc-banner-btns {
        display: flex;
        gap: 8px;
      }
      .loc-btn {
        flex: 1;
        padding: 9px 12px;
        border-radius: 10px;
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.15s;
      }
      .loc-btn:active {
        opacity: 0.75;
      }
      .loc-btn.allow {
        background: var(--blue);
        color: #fff;
      }
      .loc-btn.deny {
        background: transparent;
        border: 1px solid var(--line2);
        color: var(--text2);
      }
      .critical-strip {
        background: var(--red);
        padding: 9px 20px;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .critical-strip-text {
        font-family: 'DM Mono', monospace;
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #fff;
      }
      .critical-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #fff;
        animation: dot-blink 1.1s ease-in-out infinite;
        flex-shrink: 0;
      }
      @keyframes dot-blink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.2;
        }
      }
      .critical-strip-spacer {
        flex: 1;
      }
      .critical-time {
        font-family: 'DM Mono', monospace;
        font-size: 0.6rem;
        color: rgba(255, 255, 255, 0.7);
        letter-spacing: 0.06em;
      }
      .hero {
        position: relative;
        overflow: hidden;
        background: var(--bg1);
        padding-bottom: 0;
      }
      .hero-glow {
        position: absolute;
        top: -60px;
        left: -40px;
        width: 280px;
        height: 280px;
        background: radial-gradient(circle, rgba(255, 61, 61, 0.14) 0%, transparent 70%);
        pointer-events: none;
      }
      .hero-glow2 {
        position: absolute;
        bottom: -40px;
        right: -60px;
        width: 200px;
        height: 200px;
