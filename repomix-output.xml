import { ApiError } from '#shared/response/ApiError.js';
import * as repo from './class.repository.js';

export const list = async (req) => {
  const { schoolId } = req.user;
  if (!schoolId) throw ApiError.tenantRequired();
  return repo.findBySchool(schoolId, req.query);
};

export const getOne = async (id, schoolId) => {
  const classGroup = await repo.findById(id, schoolId);
  if (!classGroup) throw ApiError.notFound('Class not found');
  return classGroup;
};

export const create = async (data, schoolId) => {
  // Check duplicate
  const duplicate = await repo.findDuplicate(schoolId, data.grade, data.section);
  if (duplicate) throw ApiError.conflict(`Class ${data.grade}-${data.section} already exists`);
  return repo.create(schoolId, data);
};

export const update = async (id, data, schoolId) => {
  const classGroup = await repo.findById(id, schoolId);
  if (!classGroup) throw ApiError.notFound('Class not found');

  // Check duplicate if grade/section changed
  if (data.grade || data.section) {
    const grade = data.grade || classGroup.grade;
    const section = data.section || classGroup.section;
    if (grade !== classGroup.grade || section !== classGroup.section) {
      const duplicate = await repo.findDuplicate(schoolId, grade, section);
      if (duplicate && duplicate.id !== id) {
        throw ApiError.conflict(`Class ${grade}-${section} already exists`);
      }
    }
  }

  return repo.update(id, data);
};

export const remove = async (id, schoolId) => {
  const classGroup = await repo.findById(id, schoolId);
  if (!classGroup) throw ApiError.notFound('Class not found');
  return repo.remove(id);
};

export const bulkCreate = async (classes, schoolId) => {
  const result = await repo.bulkCreate(schoolId, classes);
  return { count: result.count };
};

export const getStats = async (schoolId) => {
  return repo.getStats(schoolId);
};

export const getDropdown = async (schoolId) => {
  return repo.findForDropdown(schoolId);
};
