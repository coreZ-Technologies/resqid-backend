  code String? @unique

  // ─── Basic Info ───
  board       Board             @default(OTHER)
  type        SchoolType        @default(K12)
  affiliation SchoolAffiliation @default(PRIVATE)
  estYear     Int? // Establishment year

  // ─── Address ───
  street     String?
  city       String?
  state      String?
  country    String? @default("India")
  postalCode String?
  latitude   Float?
  longitude  Float?

  // ─── Contact ───
  email   String?
  phone   String?
  website String?
  logoUrl String?

  // ─── Timezone ───
  timezone String @default("Asia/Kolkata")

  // ─── Academic Calendar ───
  academicYearStart DateTime? // e.g., "2024-04-01"
  academicYearEnd   DateTime? // e.g., "2025-03-31"

  // ─── School Timing ───
  schoolStartTime String? // "08:00"
  schoolEndTime   String? // "15:00"
  workingDays     Int[]   @default([1, 2, 3, 4, 5, 6]) // 1=Mon
  currentTerm     String? // "First Term", "Second Term"

  // ─── Subscription ───
  planId String?
  plan   Plan?        @relation(fields: [planId], references: [id])
  status SchoolStatus @default(TRIAL)

  // ─── Feature Toggles ───
  features Json @default("{}")
  // Example: {"emergency":true, "attendance":true, "timetable":false, "transport":false}

  // ─── Timestamps ───
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Relations ───
  users             SchoolUser[]
  students          Student[]
  teachers          Teacher[]
  tokens            Token[]
  scans             Scan[]
  subscriptions     Subscription[]
  orders            Order[]
  attendanceDevices AttendanceDevice[]
  announcements     Announcement[]
  messages          Message[]
  notifications     Notification[]

  // Timetable Relations
  timetableConfig    SchoolTimetableConfig?
  rooms              Room[]
  subjects           Subject[]
  classGroups        ClassGroup[]
  timetableTemplates TimetableTemplate[]
  timetables         Timetable[]
  crisisEvents       CrisisEvent[]
  substitution       Substitution[]
  timetableJobs      TimetableJob[]
  bulkUploads        BulkUpload[]
  constraintPresets  ConstraintPreset[]

  // Emergency Relations
  emergencyProfiles   EmergencyProfile[]
  emergencyIncidents  EmergencyIncident[]
  emergencyDrills     EmergencyDrill[]
  emergencyAccessLogs EmergencyAccessLog[]

  // Audit Relations
  auditLogs                AuditLog[]
  payments                 Payment[]
  invoices                 Invoice[]
  scanAnomalies            ScanAnomaly[]
  scanLogs                 ScanLog[]
  qrBatchGenerations       QrBatchGeneration[]
  trustedScanZones         TrustedScanZone[]
  attendanceSessions       AttendanceSession[]
  attendanceTaps           AttendanceTap[]
  studentAttendanceRecords StudentAttendanceRecord[]
  staffAttendanceRecords   StaffAttendanceRecord[]
  attendanceReports        AttendanceReport[]
  attendanceSettings       AttendanceSettings?
  attendanceSummaries      AttendanceSummary[]
  messageTemplates         MessageTemplate[]
  notificationQueues       NotificationQueue[]
  communicationCampaigns   CommunicationCampaign[]
  teacherWellnesses        TeacherWellness[]
  notificationTemplates    NotificationTemplate[]
  notificationBatches      NotificationBatch[]

  @@index([status])
  @@index([board])
  @@index([city, state])
  @@map("schools")
}
</file>

<file path="prisma/schema/core/token.prisma">
// =============================================================================
// prisma/schema/core/token.prisma — RESQID
// Physical and digital tokens assigned to students
// QR codes, RFID cards, NFC tags management
// =============================================================================

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TokenType {
  RFID
  QR
  NFC
  COMBO // Both QR + RFID
}

enum TokenStatus {
  UNREGISTERED
  ISSUED
  ACTIVE
  INACTIVE
  REVOKED
  LOST
  EXPIRED
}

enum ScanResult {
  INVALID
  UNREGISTERED
  ISSUED
  INACTIVE
  REVOKED
  ACTIVE
  BLOCKED
  SUSPICIOUS
  EXPIRED
}

enum QrFormat {
  PNG
  SVG
  PDF
}

// ─── Token Model ──────────────────────────────────────────────────────────────

model Token {
  id String @id @default(cuid())

  // Student Assignment
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])

  // Token Type & Physical IDs
  type    TokenType @default(QR)
  rfidUid String?   @unique // RFID card UID (for RFID/COMBO tokens)

  // QR Code Identifiers
  qrCode     String? @unique // Unique QR identifier (e.g., "RESQID-STU-2024-001234")
  qrCodeHash String? @unique // Hashed version for secure lookup

  // Encrypted Scan Code (for QR URL security)
  scanCode            String?   @unique // AES-SIV encrypted scan payload
  scanCodeHash        String?   @unique // Hash of scan code for fast lookup
  scanCodeEncryptedAt DateTime? // When scan code was last encrypted

  // QR Asset (Generated QR Image)
  qrGenerated         Boolean   @default(false) // Has QR been generated?
  qrFormat            QrFormat? // PNG, SVG, PDF
  qrWidthPx           Int? // QR image width
  qrHeightPx          Int? // QR image height
  qrFileSizeKb        Float? // File size in KB
  qrAssetUrl          String? // Cloud storage URL for QR image
  qrGeneratedAt       DateTime? // When QR was first generated
  qrRegeneratedAt     DateTime? // Last regeneration time
  qrRegenerationCount Int       @default(0) // How many times regenerated

  // QR Background/Logo Customization (Optional)
  qrForegroundColor String? @default("#000000") // QR code color
  qrBackgroundColor String? @default("#FFFFFF") // Background color
  qrLogoUrl         String? // Center logo URL
  qrErrorCorrection String? @default("M") // L, M, Q, H

  // Token Status & Lifecycle
  status       TokenStatus @default(UNREGISTERED)
  issuedAt     DateTime? // When token was issued
  activatedAt  DateTime? // When token was activated
  expiresAt    DateTime? // Token expiry date
  revokedAt    DateTime? // When revoked
  revokedBy    String? // Who revoked it (admin ID)
  revokeReason String? // Reason for revocation

  // Token Label & Notes
  label    String? // Human-readable label
  notes    String? // Internal notes
  batchId  String? // Batch ID for bulk token generation
  metadata Json? // Flexible metadata

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  scans     Scan[]
  scanLogs  ScanLog[]
  orderItem OrderItem?

  @@index([studentId])
  @@index([schoolId, type])
  @@index([schoolId, status])
  @@index([rfidUid])
  @@index([qrCode])
  @@index([qrCodeHash])
  @@index([scanCodeHash])
  @@index([batchId])
  @@map("tokens")
}

// ─── Scan Log ─────────────────────────────────────────────────────────────────

model ScanLog {
  id       String @id @default(cuid())
  tokenId  String
  token    Token  @relation(fields: [tokenId], references: [id])
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Scan Result
  scannedAt   DateTime   @default(now())
  result      ScanResult
  scanType    String?
  scanPurpose String?

  // Scanner Info
  scannerId   String?
  scannerName String?

  // Location
  ipAddress String?
  city      String?
  country   String?
  latitude  Float?
  longitude Float?

  // Device
  device      String?
  deviceModel String?
  os          String?
  browser     String?
  userAgent   String?

  // Security
  isBot        Boolean @default(false)
  isSuspicious Boolean @default(false)
  riskScore    Float?

  // Performance
  responseTimeMs Int?

  // Student Snapshot
  studentName    String?
  studentClass   String?
  studentSection String?

  metadata Json?
}

// ─── Scan Rate Limit ──────────────────────────────────────────────────────────

model ScanRateLimit {
  id             String @id @default(cuid())
  identifier     String // IP address, token ID, or device fingerprint
  identifierType String // IP | TOKEN | DEVICE | USER

  // Rate Limiting
  count       Int @default(0) // Current window count
  blockCount  Int @default(0) // How many times blocked
  maxRequests Int @default(100) // Max requests per window

  // Block Status
  blockedUntil  DateTime? // If blocked, until when
  blockedReason String? // Why blocked

  // Window Tracking
  lastHit        DateTime @default(now())
  windowStart    DateTime @default(now())
  windowDuration Int      @default(60) // Window in seconds

  metadata Json?

  @@unique([identifier, identifierType])
  @@index([identifier])
  @@index([blockedUntil])
  @@map("scan_rate_limits")
}

// ─── QR Batch Generation ──────────────────────────────────────────────────────

model QrBatchGeneration {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Batch Details
  name         String // "Batch 2024-2025 - Class 10"
  batchId      String @unique
  totalCount   Int // Total tokens in batch
  successCount Int    @default(0)
  failedCount  Int    @default(0)

  // QR Settings Used
  format          QrFormat @default(PNG)
  widthPx         Int      @default(512)
  heightPx        Int      @default(512)
  errorCorrection String   @default("M")

  // Status
  status String @default("PROCESSING") // PENDING, PROCESSING, COMPLETED, FAILED

  // Generated by
  createdById String?
  createdBy   SchoolUser? @relation(fields: [createdById], references: [id])

  // Results
  errorLog Json? // Array of errors if any

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([schoolId])
  @@index([batchId])
  @@index([status])
  @@map("qr_batch_generations")
}
</file>

<file path="prisma/schema/modules/communication.prisma">
// =============================================================================
// prisma/schema/modules/communication.prisma — RESQID
// Announcements, parent messaging, and notifications
// Uses: SchoolUser (staff), Student, ParentUser
// NotificationChannel enum from shared/notification.prisma
// =============================================================================

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AnnouncementTarget {
  ALL
  GRADE
  SECTION
  STUDENT
  PARENT
  STAFF
  CUSTOM
}

enum MessageDirection {
  SCHOOL_TO_PARENT
  PARENT_TO_SCHOOL
  SYSTEM
}

enum MessageType {
  GENERAL
  ATTENDANCE
  FEE_REMINDER
  EVENT_INVITATION
  REPORT_CARD
  EMERGENCY
  ABSENT_NOTIFICATION
  HOMEWORK
  EXAM_SCHEDULE
  PAYMENT_RECEIPT
  TIMETABLE_CHANGE // Added for timetable notifications
  SUBSTITUTION_ALERT // Added for substitution alerts
  CRISIS_ALERT // Added for crisis communication
}

enum MessageStatus {
  DRAFT
  SCHEDULED
  SENT
  DELIVERED
  READ
  REPLIED
  FAILED
  CANCELLED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

// ─── Announcement Model ──────────────────────────────────────────────────────

model Announcement {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Author (SchoolUser - teacher/admin)
  authorId String
  author   SchoolUser @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  // Content
  title       String
  body        String
  imageUrl    String?
  attachments String[] // URLs to attached files
  priority    AnnouncementPriority @default(NORMAL)

  // Targeting
  target           AnnouncementTarget @default(ALL)
  targetGrades     String[] // ["10", "11", "12"]
  targetSections   String[] // ["A", "B"]
  targetClassIds   String[] // ClassGroup IDs for precise targeting
  targetStudentIds String[] // Specific student IDs
  isPublic         Boolean            @default(false) // Visible to parents without login

  // Scheduling
  publishedAt DateTime?
  expiresAt   DateTime?
  isArchived  Boolean   @default(false)

  // Stats (updated by delivery tracking)
  totalRecipients Int @default(0)
  deliveredCount  Int @default(0)
  readCount       Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  deliveries AnnouncementDelivery[]

  @@index([schoolId])
  @@index([schoolId, target])
  @@index([publishedAt])
  @@index([expiresAt])
  @@index([authorId])
  @@map("announcements")
}

// ─── Announcement Delivery (Track who received/read) ──────────────────────────

model AnnouncementDelivery {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  // Recipient (can be parent or staff)
  parentId String?
  parent   ParentUser? @relation(fields: [parentId], references: [id])
  staffId  String?
  staff    SchoolUser? @relation(fields: [staffId], references: [id])

  // Delivery Status
  channel     NotificationChannel // From notification.prisma
  status      MessageStatus       @default(SENT)
  deliveredAt DateTime?
  readAt      DateTime?

  // For SMS/Email tracking
  externalId String? // External service message ID
  error      String? // Delivery error message
  retryCount Int     @default(0)

  createdAt DateTime @default(now())

  @@unique([announcementId, parentId, channel])
  @@unique([announcementId, staffId, channel])
  @@index([announcementId])
  @@index([parentId])
  @@index([staffId])
  @@index([status])
  @@index([channel])
  @@map("announcement_deliveries")
}

// ─── Message Model (Direct Communication) ─────────────────────────────────────

model Message {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Thread ID for conversation grouping
  threadId String?

  // Direction & Type
  direction MessageDirection @default(SCHOOL_TO_PARENT)
  type      MessageType      @default(GENERAL)

  // Participants
  senderId  String? // SchoolUser ID (if school → parent)
  sender    SchoolUser? @relation("MessageSender", fields: [senderId], references: [id])
  parentId  String? // ParentUser ID
  parent    ParentUser? @relation(fields: [parentId], references: [id])
  studentId String? // Related student (optional)
  student   Student?    @relation(fields: [studentId], references: [id])

  // Content
  subject     String?
  body        String
  attachments String[] // URLs to attached files

  // Status Tracking
  status    MessageStatus @default(SENT)
  isRead    Boolean       @default(false)
  readAt    DateTime?
  repliedTo String? // Message ID this is replying to

  // Delivery Channels
  channels NotificationChannel[] // From notification.prisma

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  replies       Message[] @relation("MessageReplies")
  parentMessage Message?  @relation("MessageReplies", fields: [repliedTo], references: [id])

  // Link to related entities
  timetableId String?
  timetable   Timetable?   @relation(fields: [timetableId], references: [id], onDelete: SetNull)
  crisisId    String?
  crisis      CrisisEvent? @relation(fields: [crisisId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([threadId])
  @@index([parentId])
  @@index([studentId])
  @@index([senderId])
  @@index([createdAt])
  @@index([type])
  @@map("messages")
}

// ─── Message Template (Pre-defined message templates) ─────────────────────────

model MessageTemplate {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Template Details
  name      String // "Absent Notification", "Fee Reminder", "Timetable Change"
  type      MessageType
  subject   String
  body      String // Can contain variables: {{studentName}}, {{date}}, {{amount}}, {{newTime}}
  variables String[] // ["studentName", "date", "amount"] - for UI hint

  // Who created it
  createdById String
  createdBy   SchoolUser @relation("TemplateCreator", fields: [createdById], references: [id])

  // Status
  isActive  Boolean @default(true)
  isDefault Boolean @default(false) // System default template

  // Usage Stats
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, type])
  @@index([isDefault])
  @@index([isActive])
  @@map("message_templates")
}

// ─── Notification Queue (For batch processing) ────────────────────────────────

model NotificationQueue {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Recipient
  parentId String?
  parent   ParentUser? @relation(fields: [parentId], references: [id])
  staffId  String?
  staff    SchoolUser? @relation(fields: [staffId], references: [id])

  // Content
  title         String
  body          String
  type          MessageType
  referenceId   String? // Related entity ID (attendance, fee, etc.)
  referenceType String? // "ATTENDANCE", "FEE", "EXAM", "EVENT", "TIMETABLE"

  // Delivery
  channel  NotificationChannel // From notification.prisma
  status   MessageStatus       @default(SENT)
  priority Int                 @default(5) // 1-10, lower = higher priority

  // Scheduling
  scheduledFor DateTime?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?

  // Tracking
  externalId    String? // External service ID
  attemptCount  Int       @default(0)
  maxAttempts   Int       @default(3)
  lastAttemptAt DateTime?
  error         String?

  // Deduplication
  idempotencyKey String? // Prevent duplicate sends

  // Metadata
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([scheduledFor])
  @@index([parentId])
  @@index([staffId])
  @@index([priority])
  @@index([idempotencyKey])
  @@index([schoolId, createdAt])
  @@map("notification_queue")
}

// ─── Bulk Communication Campaign ──────────────────────────────────────────────

model CommunicationCampaign {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Campaign Details
  name        String
  description String?
  type        MessageType

  // Content
  subject    String
  body       String
  templateId String? // If using a template

  // Targeting
  target         AnnouncementTarget
  targetGrades   String[]
  targetSections String[]
  targetClassIds String[]
  targetFilters  Json? // { status: "ACTIVE", feeStatus: "PENDING" }

  // Schedule
  scheduledFor DateTime?
  sentAt       DateTime?
  completedAt  DateTime?

  // Stats
  totalRecipients Int
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  readCount       Int @default(0)
  failedCount     Int @default(0)

  // Status
  status CampaignStatus @default(DRAFT)

  // Created by
  createdById String
  createdBy   SchoolUser @relation("CampaignCreator", fields: [createdById], references: [id])

  // Approved by (for large campaigns)
  approvedById String?
  approvedBy   SchoolUser? @relation("CampaignApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([scheduledFor])
  @@index([createdById])
  @@map("communication_campaigns")
}
</file>

<file path="prisma/schema/modules/emergency.prisma">
// =============================================================================
// prisma/schema/modules/emergency.prisma — RESQID
// Emergency profile and contacts — displayed on QR scan
// Handles student emergency data for quick access during emergencies
// BloodGroup enum defined here (single source of truth)
// =============================================================================

// ─── Enums ────────────────────────────────────────────────────────────────────

enum EmergencyContactRelation {
  FATHER
  MOTHER
  GUARDIAN
  GRANDPARENT
  SIBLING
  RELATIVE
  FAMILY_DOCTOR
  NEIGHBOR
  OTHER
}

enum BloodGroup {
  A_POSITIVE  @map("A+")
  A_NEGATIVE  @map("A-")
  B_POSITIVE  @map("B+")
  B_NEGATIVE  @map("B-")
  O_POSITIVE  @map("O+")
  O_NEGATIVE  @map("O-")
  AB_POSITIVE @map("AB+")
  AB_NEGATIVE @map("AB-")
  UNKNOWN
}

enum EmergencySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentType {
  INJURY
  ILLNESS
  ALLERGIC_REACTION
  ASTHMA_ATTACK
  ACCIDENT
  SEIZURE
  FAINTING
  BLEEDING
  FRACTURE
  BURN
  POISONING
  HEAD_INJURY
  BREATHING_DIFFICULTY
  DIABETIC_EMERGENCY
  OTHER
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  FOLLOW_UP_NEEDED
}

enum DrillType {
  FIRE
  EARTHQUAKE
  LOCKDOWN
  MEDICAL
  EVACUATION
  CHEMICAL_SPILL
  FLOOD
  OTHER
}

enum DrillStatus {
  SCHEDULED
  IN_PROGRESS
  CONDUCTED
  COMPLETED
  CANCELLED
}

// ─── Emergency Profile (One per student) ──────────────────────────────────────

model EmergencyProfile {
  id        String  @id @default(cuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id])

  // ─── Medical Information (Quick Reference) ───
  bloodGroup   BloodGroup @default(UNKNOWN)
  allergies    String[] // ["Peanuts", "Dust Mites", "Penicillin"]
  medications  String[] // ["Inhaler (Salbutamol)", "EpiPen"]
  conditions   String[] // ["Asthma", "Diabetes Type 1", "Epilepsy"]
  medicalNotes String? // Additional medical context

  // ─── Doctor Information ───
  doctorName           String?
  doctorPhone          String?
  doctorSpecialization String?
  doctorClinic         String?
  doctorAddress        String?

  // ─── Hospital Preference ───
  hospitalName    String?
  hospitalPhone   String?
  hospitalAddress String?

  // ─── Insurance Information ───
  insuranceProvider     String?
  insurancePolicyNumber String?
  insuranceValidUntil   DateTime?

  // ─── Emergency Instructions ───
  emergencyInstructions String? // "In case of asthma attack, use blue inhaler. If no improvement in 5 mins, call ambulance."
  specialNeeds          String? // "Uses hearing aid", "Wheelchair user", "Non-verbal"

  // ─── Visibility Controls (what shows on QR scan) ───
  showBloodGroup   Boolean @default(true)
  showAllergies    Boolean @default(true)
  showMedications  Boolean @default(true)
  showConditions   Boolean @default(true)
  showContacts     Boolean @default(true)
  showDoctorInfo   Boolean @default(true)
  showInstructions Boolean @default(true)
  showInsurance    Boolean @default(false)
  showSpecialNeeds Boolean @default(true)

  // ─── Profile Completion ───
  isComplete  Boolean   @default(false)
  completedAt DateTime?

  // ─── Last Verification ───
  lastVerifiedAt DateTime?
  verifiedBy     String? // SchoolUser ID who verified

  // ─── Timestamps ───
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Relations ───
  contacts  EmergencyContact[]
  incidents EmergencyIncident[]

  @@index([schoolId])
  @@index([bloodGroup])
  @@index([isComplete])
  @@map("emergency_profiles")
}

// ─── Emergency Contact Model ──────────────────────────────────────────────────

model EmergencyContact {
  id        String           @id @default(cuid())
  profileId String
  profile   EmergencyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // ─── Contact Details ───
  name           String
  phone          String
  alternatePhone String?
  email          String?
  relation       EmergencyContactRelation
  address        String?
  photoUrl       String? // For quick identification

  // ─── Priority & Roles ───
  isPrimary       Boolean @default(false)
  priority        Int     @default(0) // 0 = highest priority
  isLegalGuardian Boolean @default(false) // Legal guardian status

  // ─── Communication Preferences ───
  isActive        Boolean @default(true)
  callEnabled     Boolean @default(true)
  whatsappEnabled Boolean @default(false)
  smsEnabled      Boolean @default(true)

  // ─── Availability ───
  available24x7 Boolean @default(false)
  availableFrom String? // "09:00" (if not 24x7)
  availableTo   String? // "18:00"
  timezone      String? // "Asia/Kolkata"

  // ─── Relationship to Student ───
  canPickup      Boolean @default(false) // Authorized for pickup
  pickupPassword String? // Optional password for pickup
  notes          String? // "Prefers calls over messages", "Works night shifts"

  // ─── Timestamps ───
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([priority])
  @@index([isPrimary])
  @@index([phone])
  @@map("emergency_contacts")
}

// ─── Emergency Incident Log ───────────────────────────────────────────────────

model EmergencyIncident {
  id        String            @id @default(cuid())
  studentId String
  student   Student           @relation(fields: [studentId], references: [id])
  profileId String?
  profile   EmergencyProfile? @relation(fields: [profileId], references: [id])
  schoolId  String
  school    School            @relation(fields: [schoolId], references: [id])

  // ─── Incident Details ───
  type        IncidentType
  severity    EmergencySeverity
  description String // What happened
  location    String? // "Playground", "Classroom 10A", "School Bus"

  // ─── Timing ───
  occurredAt          DateTime
  reportedAt          DateTime  @default(now())
  resolvedAt          DateTime?
  responseTimeMinutes Int? // How quickly staff responded

  // ─── Actions Taken ───
  actionTaken     String // "Administered inhaler", "Called parents", "Rushed to hospital"
  medicationGiven String? // "Inhaler 2 puffs", "EpiPen administered"

  // ─── People Involved ───
  reportedById String?
  reportedBy   SchoolUser? @relation("IncidentReporter", fields: [reportedById], references: [id])
  handledById  String?
  handledBy    SchoolUser? @relation("IncidentHandler", fields: [handledById], references: [id])

  // ─── External Help ───
  ambulanceCalled Boolean @default(false)
  hospitalName    String?
  hospitalVisitId String?

  // ─── Parent Notification ───
  parentNotified     Boolean   @default(false)
  parentNotifiedAt   DateTime?
  parentArrived      Boolean   @default(false)
  parentArrivedAt    DateTime?
  contactedContactId String? // Which emergency contact was reached

  // ─── Follow-up ───
  followUpRequired Boolean   @default(false)
  followUpNotes    String?
  followUpDate     DateTime?

  // ─── Status ───
  status IncidentStatus @default(OPEN)

  // ─── Attachments ───
  attachments String[] // URLs to photos, reports

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([schoolId])
  @@index([severity])
  @@index([occurredAt])
  @@index([status])
  @@index([type])
  @@map("emergency_incidents")
}

// ─── Emergency Drill Log ──────────────────────────────────────────────────────

model EmergencyDrill {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // ─── Drill Details ───
  type        DrillType
  description String?

  // ─── Timing ───
  scheduledFor    DateTime?
  conductedAt     DateTime?
  completedAt     DateTime?
  durationMinutes Int?

  // ─── Participation ───
  totalStudents  Int
  totalStaff     Int
  evacuationTime Int? // Seconds
  successRate    Float? // Percentage (0-100)

  // ─── Conducted By ───
  conductedById String?
  conductedBy   SchoolUser? @relation(fields: [conductedById], references: [id])

  // ─── Notes ───
  observations String? // What went well
  improvements String? // What needs improvement
  incidents    String? // Any incidents during drill

  // ─── Status ───
  status DrillStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([type])
  @@index([conductedAt])
  @@index([status])
  @@map("emergency_drills")
}

// ─── Emergency Contacts Quick-Access Log ──────────────────────────────────────

model EmergencyAccessLog {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id])

  // ─── Who accessed ───
  accessedById String?
  accessedBy   SchoolUser? @relation(fields: [accessedById], references: [id])

  // ─── How accessed ───
  method    String // "QR_SCAN", "APP", "DASHBOARD", "API"
  deviceId  String?
  ipAddress String?

  // ─── What was viewed ───
  viewedBloodGroup  Boolean @default(false)
  viewedAllergies   Boolean @default(false)
  viewedContacts    Boolean @default(false)
  viewedConditions  Boolean @default(false)
  viewedMedications Boolean @default(false)
  calledContact     Boolean @default(false)
  contactedId       String? // Which contact was called

  // ─── Context ───
  reason     String? // Why was it accessed
  incidentId String? // Linked to an incident

  accessedAt DateTime @default(now())

  @@index([studentId])
  @@index([schoolId])
  @@index([accessedAt])
  @@index([method])
  @@map("emergency_access_logs")
}
