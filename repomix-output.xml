    <script>
      // ── Security ────────────────────────────────────────────
      document.addEventListener('contextmenu', (e) => e.preventDefault());
      document.addEventListener('keydown', (e) => {
        const b =
          e.key === 'F12' ||
          (e.ctrlKey && e.shiftKey && ['I', 'J', 'C', 'K'].includes(e.key)) ||
          (e.ctrlKey && ['U', 'S', 'P'].includes(e.key));
        if (b) e.preventDefault();
      });

      // ── Helpers ─────────────────────────────────────────────
      const esc = (s) =>
        s
          ? String(s).replace(
              /[&<>"']/g,
              (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]
            )
          : '';
      const initials = (name) =>
        name
          ? name
              .split(' ')
              .map((w) => w[0])
              .slice(0, 2)
              .join('')
              .toUpperCase()
          : '?';

      function getToken() {
        const parts = window.location.pathname.split('/');
        return parts.filter(Boolean).pop() || null;
      }
      function nowStr() {
        return new Date().toLocaleTimeString('en-IN', {
          hour: '2-digit',
          minute: '2-digit',
          hour12: true,
        });
      }

      // ── CDN URL fixer ──────────────────────────────────────
      function fixCdnUrl(url) {
        if (!url) return null;
        if (url.startsWith('http')) return url;
        return 'https://assets.getresqid.in/' + url.replace(/^\//, '');
      }

      // ── Location ────────────────────────────────────────────
      const LOC_KEY = 'rq_loc_dec',
        LOC_DATA = 'rq_loc_data';
      const cachedLoc = () => {
        try {
          const d = sessionStorage.getItem(LOC_DATA);
          return d ? JSON.parse(d) : null;
        } catch {
          return null;
        }
      };
      const prevDec = () => {
        try {
          return sessionStorage.getItem(LOC_KEY);
        } catch {
          return null;
        }
      };
      const saveDec = (v) => {
        try {
          sessionStorage.setItem(LOC_KEY, v);
        } catch {}
      };
      const saveLoc = (l) => {
        try {
          sessionStorage.setItem(LOC_DATA, JSON.stringify(l));
        } catch {}
      };

      function showLocBanner() {
        return new Promise((res) => {
          const el = document.createElement('div');
          el.className = 'loc-banner';
          el.innerHTML = `<div class="loc-banner-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="#4d8eff" stroke-width="1.8"/><circle cx="12" cy="9" r="2.5" stroke="#4d8eff" stroke-width="1.8"/></svg></div><div class="loc-banner-body"><p class="loc-banner-title">Share your location?</p><p class="loc-banner-desc">Helps first responders reach you faster. Only used during this emergency scan.</p><div class="loc-banner-btns"><button class="loc-btn allow">Allow Location</button><button class="loc-btn deny">Skip</button></div></div>`;
          document.body.appendChild(el);
          el.querySelector('.allow').onclick = () => {
            el.remove();
            res(true);
          };
          el.querySelector('.deny').onclick = () => {
            el.remove();
            res(false);
          };
        });
      }

      async function resolveLocation() {
        const c = cachedLoc();
        if (c) return c;
        const prev = prevDec();
        if (prev === 'denied') return null;
        if (prev === 'granted') {
          return new Promise((res) => {
            if (!navigator.geolocation) {
              res(null);
              return;
            }
            navigator.geolocation.getCurrentPosition(
              (pos) => {
                const l = {
                  latitude: pos.coords.latitude,
                  longitude: pos.coords.longitude,
                  accuracy: pos.coords.accuracy,
                };
                saveLoc(l);
                res(l);
              },
              () => res(null),
              { enableHighAccuracy: true, timeout: 8000, maximumAge: 60000 }
            );
          });
        }
        const allowed = await showLocBanner();
        if (!allowed) {
          saveDec('denied');
          return null;
        }
        saveDec('granted');
        if (!navigator.geolocation) return null;
        return new Promise((res) => {
          const t = document.createElement('div');
          t.className = 'toast';
          t.innerHTML = '<div class="toast-spinner"></div><span>Getting precise location…</span>';
          document.body.appendChild(t);
          navigator.geolocation.getCurrentPosition(
            (pos) => {
              t.remove();
              const l = {
                latitude: pos.coords.latitude,
                longitude: pos.coords.longitude,
                accuracy: pos.coords.accuracy,
              };
              saveLoc(l);
              res(l);
            },
            () => {
              t.remove();
              res(null);
            },
            { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
          );
        });
      }

      function buildUrl(base, loc) {
        if (!loc?.latitude) return base;
        const sep = base.includes('?') ? '&' : '?';
        return `${base}${sep}lat=${loc.latitude}&lng=${loc.longitude}&acc=${loc.accuracy || 0}`;
      }

