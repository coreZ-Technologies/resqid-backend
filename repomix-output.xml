import { ApiResponse } from '#shared/response/ApiResponse.js';
import { asyncHandler } from '#shared/response/asyncHandler.js';
import * as service from './anomaly.service.js';
import {
  anomalyListQuerySchema,
  anomalyIdParamsSchema,
  resolveAnomalySchema,
} from './anomaly.validation.js';

export const list = asyncHandler(async (req, res) => {
  const query = anomalyListQuerySchema.parse(req.query);
  req.query = query;
  const { anomalies, total } = await service.list(req);
  ApiResponse.paginated(res, anomalies, { page: query.page, limit: query.limit, total });
});

export const getOne = asyncHandler(async (req, res) => {
  const { id } = anomalyIdParamsSchema.parse(req.params);
  const anomaly = await service.getOne(id, req);
  ApiResponse.ok(res, anomaly);
});

export const resolve = asyncHandler(async (req, res) => {
  const { id } = anomalyIdParamsSchema.parse(req.params);
  const parsed = resolveAnomalySchema.parse(req.body);
  const anomaly = await service.resolve(id, parsed, req);
  ApiResponse.ok(res, anomaly, 'Anomaly resolved');
});

export const stats = asyncHandler(async (req, res) => {
  const result = await service.getStats(req.schoolId);
  ApiResponse.ok(res, result);
});
