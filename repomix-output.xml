import { prisma } from '#config/prisma.js';
import { hashPassword } from '#shared/security/hashUtil.js';

// ─── List by School ───────────────────────────────────────────────────────────

export const findBySchool = async (schoolId, query = {}) => {
  const {
    page = 1,
    limit = 20,
    search,
    subject,
    status,
    isPartTime,
    sortBy = 'name',
    sortOrder = 'asc',
  } = query;

  const where = { schoolId, deletedAt: null };
  if (search) {
    where.OR = [
      { name: { contains: search, mode: 'insensitive' } },
      { email: { contains: search, mode: 'insensitive' } },
      { employeeId: { contains: search, mode: 'insensitive' } },
    ];
  }
  if (subject) where.subjects = { has: subject };
  if (isPartTime !== undefined) where.isPartTime = isPartTime;
  if (status === 'active') {
    where.isActive = true;
    where.isOnLeave = false;
  }
  if (status === 'on_leave') where.isOnLeave = true;
  if (status === 'inactive') where.isActive = false;

  const [teachers, total] = await Promise.all([
    prisma.teacher.findMany({
      where,
      skip: (page - 1) * limit,
      take: limit,
      orderBy: { [sortBy]: sortOrder },
      select: {
        id: true,
        name: true,
        email: true,
        phone: true,
        employeeId: true,
        subjects: true,
        qualifications: true,
        experience: true,
        maxPeriodsPerDay: true,
        maxPeriodsPerWeek: true,
        isPartTime: true,
        isActive: true,
        isOnLeave: true,
        joiningDate: true,
        createdAt: true,
        wellness: {
          select: {
            isPregnant: true,
            isSenior: true,
            burnoutRisk: true,
            needsAccessibleRoom: true,
            needsGroundFloor: true,
            avoidEarlyMorning: true,
          },
        },
        classGroups: { select: { id: true, grade: true, section: true, label: true } },
        _count: { select: { timetableAssignments: true } },
      },
    }),
    prisma.teacher.count({ where }),
  ]);

  return { teachers, total };
};

// ─── Find All (Super Admin) ───────────────────────────────────────────────────

export const findAll = async (query = {}) => {
  const {
    page = 1,
    limit = 20,
    search,
    subject,
    schoolId,
    sortBy = 'createdAt',
    sortOrder = 'desc',
  } = query;

  const where = { deletedAt: null };
  if (schoolId) where.schoolId = schoolId;
  if (subject) where.subjects = { has: subject };
  if (search) {
    where.OR = [
      { name: { contains: search, mode: 'insensitive' } },
      { email: { contains: search, mode: 'insensitive' } },
    ];
  }

  const [teachers, total] = await Promise.all([
    prisma.teacher.findMany({
      where,
      skip: (page - 1) * limit,
      take: limit,
      orderBy: { [sortBy]: sortOrder },
      select: {
        id: true,
        name: true,
        email: true,
        phone: true,
        employeeId: true,
        subjects: true,
        qualifications: true,
        experience: true,
        isActive: true,
        isOnLeave: true,
        createdAt: true,
        school: { select: { id: true, name: true } },
        _count: { select: { classGroups: true } },
      },
    }),
    prisma.teacher.count({ where }),
  ]);

  return { teachers, total };
};

// ─── Find Class Teacher (For Parent) ──────────────────────────────────────────

export const findClassTeacher = async (schoolId, grade, section) => {
  const classGroup = await prisma.classGroup.findFirst({
    where: { schoolId, grade, section, isActive: true },
    select: {
      teacher: {
        select: {
          id: true,
          name: true,
          email: true,
          phone: true,
          subjects: true,
          qualifications: true,
          photoUrl: true,
        },
      },
    },
