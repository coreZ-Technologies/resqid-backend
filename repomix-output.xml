  EXCUSED
  HALF_DAY
  HOLIDAY
}

enum SessionType {
  MORNING
  AFTERNOON
  FULL_DAY
  EVENT
  EXAM
  STAFF_MEETING
  DUTY
}

enum AttendanceMode {
  RFID
  BIOMETRIC
  QR_CODE
  MANUAL
  GPS
  SELF
}

enum ReportFormat {
  JSON
  PDF
  CSV
  EXCEL
}

enum ReportType {
  STUDENT
  STAFF
  CLASS
  DAILY
  MONTHLY
  YEARLY
}

enum SummaryPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// ─── Attendance Session ───────────────────────────────────────────────────────

model AttendanceSession {
