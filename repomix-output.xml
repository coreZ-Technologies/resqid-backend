// =============================================================================
// prisma/schema/core/student.prisma — RESQID
// Student entity with parent links, emergency profile & card visibility
// Supports: Smart Attendance, Emergency Profile, QR Card System
// =============================================================================

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  SUSPENDED
}

enum VisibilityLevel {
  PUBLIC
  MINIMAL
  HIDDEN
}

enum Relationship {
  FATHER
  MOTHER
  GUARDIAN
  GRANDPARENT
  SIBLING
  OTHER
}

enum DocumentType {
  BIRTH_CERTIFICATE
  TRANSFER_CERTIFICATE
  MEDICAL_REPORT
  IMMUNIZATION_RECORD
  ID_PROOF
  PASSPORT
  AADHAR_CARD
  PARENT_ID
  PHOTO
  OTHER
}

// ─── Student Model ────────────────────────────────────────────────────────────

model Student {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // ─── Personal Information ───
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  gender      Gender?
  bloodGroup  BloodGroup?
  photoUrl    String?

  // ─── Academic Information ───
  grade        String?
  section      String?
  rollNumber   String?
  studentId    String? // School-issued student ID (e.g., "SCT-2024-001")
  classGroupId String? // Link to timetable class group
  classGroup   ClassGroup? @relation(fields: [classGroupId], references: [id])

  // ─── Medical Quick Info (for emergencies) ───
  allergies    String[]
  conditions   String[]
  medications  String[]
  medicalNotes String? // Additional medical instructions

  // ─── Status ───
  status      StudentStatus @default(ACTIVE)
  isActive    Boolean       @default(true)
  enrolledAt  DateTime      @default(now())
  graduatedAt DateTime?

  // ─── Card Visibility Control ───
  cardVisibilityId String?
  cardVisibility   CardVisibility? @relation(fields: [cardVisibilityId], references: [id])

  // ─── Transport ───
  transportRoute String? // Bus route number
  transportStop  String? // Pickup/Drop point
  rfidTagNumber  String? @unique // For RFID-based attendance

  // ─── Metadata ───
  metadata Json?

  // ─── Timestamps ───
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Relations ───
  tokens              Token[]
  scans               Scan[]
  attendanceRecords   StudentAttendanceRecord[]
  attendanceTaps      AttendanceTap[]
  emergencyProfile    EmergencyProfile?
  parentLinks         ParentStudent[]
  documents           StudentDocument[]
  notifications       Notification[]
  scanAnomalies       ScanAnomaly[]
  messages            Message[]
  emergencyIncidents  EmergencyIncident[]
  emergencyAccessLogs EmergencyAccessLog[]

  @@index([schoolId])
  @@index([schoolId, grade, section])
  @@index([schoolId, status])
  @@index([firstName, lastName])
  @@index([studentId])
  @@index([rfidTagNumber])
  @@index([classGroupId])
  @@map("students")
}

// ─── Card Visibility Configuration ────────────────────────────────────────────

model CardVisibility {
  id         String          @id @default(cuid())
  visibility VisibilityLevel @default(PUBLIC)

  // ─── Granular controls for MINIMAL mode ───
  showName              Boolean @default(true)
  showBloodGroup        Boolean @default(true)
  showAllergies         Boolean @default(false)
  showConditions        Boolean @default(false)
  showMedications       Boolean @default(false)
  showEmergencyContacts Boolean @default(true)
  showParentInfo        Boolean @default(false)
  showTransportInfo     Boolean @default(false)
  showPhoto             Boolean @default(true)
  showGrade             Boolean @default(true)

  // ─── Optional expiration ───
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students Student[]

  @@map("card_visibility")
}

// ─── Student Document Model ────────────────────────────────────────────────────

model StudentDocument {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  name     String // Display name: "Birth Certificate"
  type     DocumentType
  fileType String // "PDF", "JPG", "PNG"
  fileSize Int // Size in bytes
  fileUrl  String // Storage URL

  isVerified Boolean   @default(false)
  verifiedBy String? // Admin/Staff ID
  verifiedAt DateTime?

  uploadedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([studentId])
  @@index([type])
  @@map("student_documents")
}
</file>

