// =============================================================================
// modules/classes/class.repository.js — RESQID
// Purpose-built queries for each use case.
// =============================================================================

import { prisma } from '#config/prisma.js';

// ─── List (Table View) ────────────────────────────────────────────────────────

export const findBySchool = async (schoolId, query = {}) => {
  const {
    page = 1,
    limit = 20,
    grade,
    section,
    search,
    hasTeacher,
    sortBy = 'grade',
    sortOrder = 'asc',
  } = query;

  const where = { schoolId, isActive: true };

  if (grade) where.grade = grade;
  if (section) where.section = section;
  if (hasTeacher === true) where.teacherId = { not: null };
  if (hasTeacher === false) where.teacherId = null;
  if (search) {
    where.OR = [
      { grade: { contains: search, mode: 'insensitive' } },
      { section: { contains: search, mode: 'insensitive' } },
      { label: { contains: search, mode: 'insensitive' } },
    ];
  }

  const [classes, total] = await Promise.all([
    prisma.classGroup.findMany({
      where,
      skip: (page - 1) * limit,
      take: limit,
      orderBy:
        sortBy === 'grade' ? [{ grade: sortOrder }, { section: 'asc' }] : { [sortBy]: sortOrder },
      select: {
        id: true,
        grade: true,
        section: true,
        label: true,
        studentCount: true,
        periodsPerDay: true,
        createdAt: true,
        teacher: { select: { id: true, name: true, subjects: true } },
        room: { select: { id: true, roomNumber: true, roomName: true } },
        _count: { select: { students: true, timetableAssignments: true } },
      },
    }),
    prisma.classGroup.count({ where }),
  ]);

  return { classes, total };
};

// ─── Detail View ──────────────────────────────────────────────────────────────

export const findById = (id, schoolId) =>
  prisma.classGroup.findFirst({
    where: { id, schoolId },
    include: {
      teacher: { select: { id: true, name: true, email: true, phone: true } },
      room: { select: { id: true, roomNumber: true, roomName: true, type: true, capacity: true } },
      students: {
        take: 5,
        select: { id: true, firstName: true, lastName: true, rollNumber: true },
      },
      timetableAssignments: {
        take: 5,
        orderBy: [{ dayOfWeek: 'asc' }, { periodNumber: 'asc' }],
        select: {
          id: true,
          dayOfWeek: true,
          periodNumber: true,
          periodType: true,
          subject: { select: { id: true, name: true } },
          teacher: { select: { id: true, name: true } },
          room: { select: { id: true, roomNumber: true } },
        },
      },
    },
  });

// ─── Dropdown ─────────────────────────────────────────────────────────────────

export const findForDropdown = (schoolId) =>
  prisma.classGroup.findMany({
    where: { schoolId, isActive: true },
    select: { id: true, grade: true, section: true, label: true },
    orderBy: [{ grade: 'asc' }, { section: 'asc' }],
  });

// ─── Create ───────────────────────────────────────────────────────────────────

export const create = (schoolId, data) =>
  prisma.classGroup.create({
    data: {
      ...data,
      schoolId,
      label: data.label || `${data.grade}-${data.section}`,
    },
    select: {
      id: true,
      grade: true,
      section: true,
      label: true,
      studentCount: true,
      teacherId: true,
      roomId: true,
      createdAt: true,
    },
  });

// ─── Update ───────────────────────────────────────────────────────────────────

export const update = (id, data) =>
  prisma.classGroup.update({
    where: { id },
    data: {
      ...data,
      label: data.grade && data.section ? `${data.grade}-${data.section}` : undefined,
    },
  });

// ─── Delete (Soft) ────────────────────────────────────────────────────────────

export const remove = (id) =>
  prisma.classGroup.update({
    where: { id },
    data: { isActive: false },
  });

// ─── Bulk Create ──────────────────────────────────────────────────────────────

export const bulkCreate = (schoolId, classes) =>
  prisma.classGroup.createMany({
    data: classes.map((c) => ({
      ...c,
      schoolId,
      label: c.label || `${c.grade}-${c.section}`,
    })),
    skipDuplicates: true,
  });

// ─── Stats ─────────────────────────────────────────────────────────────────────

export const getStats = async (schoolId) => {
  const [total, byGrade] = await Promise.all([
    prisma.classGroup.count({ where: { schoolId, isActive: true } }),
    prisma.classGroup.groupBy({
      by: ['grade'],
      where: { schoolId, isActive: true },
      _count: true,
      orderBy: { grade: 'asc' },
    }),
  ]);

  return {
    totalClasses: total,
    byGrade: byGrade.map((g) => ({ grade: g.grade, count: g._count })),
  };
};

// ─── Check Duplicate ──────────────────────────────────────────────────────────

export const findDuplicate = (schoolId, grade, section) =>
  prisma.classGroup.findFirst({
    where: { schoolId, grade, section, isActive: true },
    select: { id: true },
  });
</file>

