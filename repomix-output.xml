 * Logout user.
 */
export const logout = asyncHandler(async (req, res) => {
  const sessionId = req.user?.sessionId;

  await authService.logout(sessionId);

  clearAuthCookies(res);
  clearCsrfCookie(res);

  return ApiResponse.ok(res, null, 'Logged out successfully');
});

/**
